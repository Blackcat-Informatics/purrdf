# Competency question: "Which events are lies?"
# A lie = deception event with held claim refuted and projected claim unequivocal.
# Expected: event-lie-001 (from dsl/statements/deception.ttl).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?event WHERE {
    ?event purrdf:eventType purrdf:eventTypeLie .
    ?event purrdf:heldStandpoint ?heldClaim .
    ?event purrdf:projectedStandpoint ?projectedClaim .
    ?heldClaim purrdf:claimModality purrdf:refuted .
    ?projectedClaim purrdf:claimModality purrdf:unequivocal .
}
ORDER BY ?event
