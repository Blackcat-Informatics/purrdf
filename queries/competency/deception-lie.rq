# Competency question: "Which events are lies?"
# A lie = deception event with held claim refuted and projected claim unequivocal.
# Expected: event-lie-001 (from dsl/statements/deception.ttl).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?event WHERE {
    ?event gmeow:eventType gmeow:eventTypeLie .
    ?event gmeow:heldStandpoint ?heldClaim .
    ?event gmeow:projectedStandpoint ?projectedClaim .
    ?heldClaim gmeow:claimModality gmeow:refuted .
    ?projectedClaim gmeow:claimModality gmeow:unequivocal .
}
ORDER BY ?event
