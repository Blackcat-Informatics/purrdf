# Competency question: "What cryptographic message signatures does PURRDF model?"
# Expected: CryptographicSignature and its subclasses (DKIM, S/MIME, PGP).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?signature WHERE {
    ?signature rdfs:subClassOf* purrdf:CryptographicSignature .
}
ORDER BY ?signature
