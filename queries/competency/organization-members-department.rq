# Competency question: "Who are members of a department and thereby members of the parent?"
# Expected: Agents that are members of a sub-organization, entailed as members of the parent
# via the existing gmeow:memberOf ∘ gmeow:subOrganizationOf property chain.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?member ?department ?parent WHERE {
    ?member gmeow:memberOf ?department .
    ?department gmeow:subOrganizationOf ?parent .
}
ORDER BY ?parent ?department ?member
