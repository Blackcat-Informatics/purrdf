# Competency question: "What gender values does GMEOW recognise?" Expected: the
# gmeow:Gender value individuals — woman, man, non-binary, agender, genderfluid,
# genderqueer, bigender, demigirl, demiboy, Two-Spirit, questioning, … plus any
# freshly minted self-described individuals. Gender values are VALUES, not Person
# subclasses — extend by adding individuals (the inclusive-without-overtyping rule).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?gender ?label WHERE {
    ?gender a gmeow:Gender .
    OPTIONAL { ?gender <http://www.w3.org/2000/01/rdf-schema#label> ?label . }
}
ORDER BY ?gender
