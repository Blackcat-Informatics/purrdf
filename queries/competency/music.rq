# Music EPIC (#306/#320) competency query bundle.
# Each UNION branch answers one competency question and binds:
#   ?question   — the question label
#   ?work       — the MusicalWork individual that is the primary answer
#   ?evidence   — a supporting individual
#
# Expected bindings are asserted in slices/extensions/music/tests/test_music_competency.py.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?question ?work ?evidence WHERE {
  {
    BIND("Q1: nested rational tuplets" AS ?question)
    BIND(purrdf:fixtureFerneyhoughWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?claim a purrdf:MusicAnalysisClaim ;
           purrdf:analysisTarget ?work ;
           purrdf:analysisResult ?evidence .
    ?evidence a purrdf:TimeMapping ;
              purrdf:timeMappingKind purrdf:timeMappingKindTuplet .
  }
  UNION
  {
    BIND("Q2: irrational tempo canon" AS ?question)
    BIND(purrdf:fixtureNancarrowTempoCanonWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?claim a purrdf:MusicAnalysisClaim ;
           purrdf:analysisTarget ?work ;
           purrdf:analysisResult ?evidence .
    ?evidence a purrdf:TimeMapping ;
              purrdf:timeMappingKind purrdf:timeMappingKindTempoCanon .
  }
  UNION
  {
    BIND("Q3: complete DegreeOfFreedom profile" AS ?question)
    BIND(purrdf:fixtureFourThirtyThreeWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?evidence a purrdf:DegreeOfFreedom ;
              purrdf:dofWork ?work .
  }
  UNION
  {
    BIND("Q4: fragment graph + TraversalConstraint + PerformanceDecisions" AS ?question)
    BIND(purrdf:fixtureStockhausenKlavierstuckXIWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?evidence a purrdf:TraversalConstraint ;
              purrdf:constraintAppliesTo ?work .
    ?decision a purrdf:PerformanceDecision ;
              purrdf:decisionConstraint ?evidence .
  }
  UNION
  {
    BIND("Q5: 43-tone just intonation with integer-pair ratios" AS ?question)
    BIND(purrdf:fixturePartch43Work AS ?work)
    ?work a purrdf:MusicalWork .
    VALUES ?evidence {
      purrdf:fixturePartchRatio1_1
      purrdf:fixturePartchRatio2_1
      purrdf:fixturePartchRatio3_2
      purrdf:fixturePartchRatio4_3
      purrdf:fixturePartchRatio5_3
      purrdf:fixturePartchRatio5_4
      purrdf:fixturePartchRatio9_8
      purrdf:fixturePartchRatio11_8
    }
    ?evidence a purrdf:PitchValue ;
              purrdf:hasTuningFrame purrdf:tuningSystemPartch43 ;
              purrdf:ratioNumerator ?num ;
              purrdf:ratioDenominator ?den .
  }
  UNION
  {
    BIND("Q6: stochastic glissando field with graphic notation" AS ?question)
    BIND(purrdf:fixtureXenakisGlissandoWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?expression a purrdf:Expression ;
                purrdf:realizes ?work ;
                purrdf:wasGeneratedBy ?evidence .
    ?evidence a purrdf:GenerativeProcess ;
              purrdf:processKind purrdf:generativeProcessKindStochastic .
  }
  UNION
  {
    BIND("Q7: spectrum-derived PitchCollection with CMN projection loss" AS ?question)
    BIND(purrdf:fixtureGriseyPartielsWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?expression a purrdf:Expression ;
                purrdf:realizes ?work .
    ?score a purrdf:ScoreEdition ;
           purrdf:embodies ?expression .
    BIND(purrdf:fixtureGriseyPartielsPitches AS ?evidence)
    ?evidence a purrdf:PitchCollection ;
              purrdf:derivedFromSpectrum purrdf:fixtureGriseyPartielsSpectrum .
  }
  UNION
  {
    BIND("Q8: graphic score with standpointed symbolic interpretations" AS ?question)
    BIND(purrdf:fixtureCardewTreatiseWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?graphic a purrdf:Expression ;
             purrdf:realizes ?work .
    ?evidence a purrdf:Expression ;
              purrdf:realizes ?work ;
              purrdf:wasDerivedFrom ?graphic .
    ?claim a purrdf:MusicAnalysisClaim ;
           purrdf:analysisTarget ?work ;
           purrdf:analysisResult ?evidence .
  }
  UNION
  {
    BIND("Q9: mensural notation with unequal talea and color cycles" AS ?question)
    BIND(purrdf:fixtureArsSubtiliorWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?claim a purrdf:MusicAnalysisClaim ;
           purrdf:analysisTarget ?work ;
           purrdf:analysisResult ?evidence .
    ?evidence a purrdf:MusicalSegment ;
              purrdf:segmentKind ?kind .
    FILTER (?kind IN (purrdf:segmentKindTalea, purrdf:segmentKindColor))
  }
  UNION
  {
    BIND("Q10: added-value MetricGroups + non-retrogradable identity + mode of limited transposition" AS ?question)
    BIND(purrdf:fixtureMessiaenExcerptWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?claim a purrdf:MusicAnalysisClaim ;
           purrdf:analysisTarget ?work ;
           purrdf:analysisProperty purrdf:analysisPropertyMode .
    BIND(?claim AS ?evidence)
  }
  UNION
  {
    BIND("Q11: unsynchronized ad-lib spans bounded by cue anchors" AS ?question)
    BIND(purrdf:fixtureLutoslawskiAdLibWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?constraint a purrdf:TraversalConstraint ;
                purrdf:constraintAppliesTo ?work .
    VALUES ?evidence {
      purrdf:fixtureLutoslawskiMappingA
      purrdf:fixtureLutoslawskiMappingB
    }
    ?evidence a purrdf:TimeMapping ;
              purrdf:timeMappingKind purrdf:timeMappingKindSyncUnsynchronized .
  }
  UNION
  {
    BIND("Q12: score-less oral tradition with ornament profile and transmission lineage" AS ?question)
    BIND(purrdf:fixtureOralRagaYamanWork AS ?work)
    ?work a purrdf:MusicalWork .
    FILTER NOT EXISTS {
      ?notated a purrdf:Expression ;
               purrdf:realizes ?work ;
               purrdf:realizationMode purrdf:realizationModeNotated .
    }
    ?event a purrdf:Event ;
           purrdf:performanceOf ?work ;
           purrdf:eventType purrdf:eventTypeTransmission .
    BIND(purrdf:fixtureRagaYamanAlapOrnamentProfile AS ?evidence)
    ?evidence a purrdf:OrnamentProfile .
  }
  UNION
  {
    BIND("Q13: additive aksak MetricGroups with changing meters" AS ?question)
    BIND(purrdf:fixtureAksakFolkTuneWork AS ?work)
    ?work a purrdf:MusicalWork .
    VALUES ?evidence {
      purrdf:fixtureAksakMeter5
      purrdf:fixtureAksakMeter7
      purrdf:fixtureAksakMeter9
    }
    ?evidence a purrdf:MetricStructure ;
              purrdf:hasMetricGroup ?group .
    ?group a purrdf:MetricGroup ;
           purrdf:groupLengthNumerator ?num ;
           purrdf:groupLengthDenominator ?den .
    FILTER (?num != ?den)
  }
  UNION
  {
    BIND("Q14: polymeter + contested meter + riff transformations + drop-D + refuted genre" AS ?question)
    BIND(purrdf:fixtureMathRockTrackWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?evidence a purrdf:MusicAnalysisClaim ;
              purrdf:analysisTarget ?work ;
              purrdf:analysisProperty purrdf:analysisPropertyMeter .
  }
  UNION
  {
    BIND("Q15: phasing generative process with realizations" AS ?question)
    BIND(purrdf:fixtureReichPhasingWork AS ?work)
    ?work a purrdf:MusicalWork .
    ?expression a purrdf:Expression ;
                purrdf:realizes ?work ;
                purrdf:wasGeneratedBy ?evidence .
    ?evidence a purrdf:GenerativeProcess ;
              purrdf:processKind purrdf:generativeProcessKindPhasing .
  }
}
