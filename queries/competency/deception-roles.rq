# Competency question: "What deception-related participant roles does PURRDF model?"
# Expected: roleDeceiver, roleDeceived, roleBeneficiaryOfDeception, roleDupe,
#           roleSpinDoctor (issue #215).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?deceptionRole WHERE {
    ?deceptionRole a purrdf:ParticipantRole .
    FILTER(?deceptionRole IN (
        purrdf:roleDeceiver,
        purrdf:roleDeceived,
        purrdf:roleBeneficiaryOfDeception,
        purrdf:roleDupe,
        purrdf:roleSpinDoctor
    ))
}
ORDER BY ?deceptionRole
