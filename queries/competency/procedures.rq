# Competency question: "What are the core procedure / execution / step terms in GMEOW?"
# Expected: Procedure, ProcedureStep, Execution, ControlFlow, DataFlow, and key properties.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT ?term WHERE {
    {
        ?term rdfs:subClassOf* gmeow:Procedure .
    } UNION {
        ?term rdfs:subClassOf* gmeow:ProcedureStep .
    } UNION {
        ?term rdfs:subClassOf* gmeow:Execution .
    } UNION {
        ?term rdfs:subClassOf* gmeow:ControlFlow .
    } UNION {
        ?term rdfs:subClassOf* gmeow:DataFlow .
    } UNION {
        ?term a owl:ObjectProperty ;
            rdfs:domain ?domain .
        FILTER(?domain IN (gmeow:Procedure, gmeow:ProcedureStep, gmeow:Execution, gmeow:ControlFlow, gmeow:DataFlow))
    }
}
ORDER BY ?term
