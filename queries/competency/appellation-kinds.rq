# Competency question: "What kinds of name (appellation) does PURRDF model as
# first-class, structurally-distinct classes?" Expected: Appellation and its
# subclasses PersonName, Filename, PlaceName, OrganizationName. A name is a
# reified object, not a flat datatype property.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?kind WHERE {
    ?kind rdfs:subClassOf* purrdf:Appellation .
}
ORDER BY ?kind
