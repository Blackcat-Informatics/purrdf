# Competency question: "Which credentials expire within one year, and who issued them?"
# Expected: credentials whose gmeow:validUntil is in the future and within roughly
# one calendar year from now, together with their issuer organization.
#
# The upper bound uses year+month arithmetic because xsd:duration arithmetic
# is not universally supported across SPARQL engines (e.g. rdflib).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?credential ?issuer ?validUntil WHERE {
    ?credential a gmeow:Credential ;
                gmeow:credentialIssuer ?issuer ;
                gmeow:validUntil ?validUntil .
    BIND(year(NOW()) AS ?nowYear)
    BIND(month(NOW()) AS ?nowMonth)
    FILTER(
        ?validUntil >= NOW() &&
        (
            year(?validUntil) < ?nowYear + 1 ||
            (year(?validUntil) = ?nowYear + 1 && month(?validUntil) <= ?nowMonth)
        )
    )
}
ORDER BY ?validUntil
