# Competency question: "What geographic place kinds does PURRDF recognise?"
# Expected: the PlaceType value individuals (country, region, city, building,
# room, …). Kinds are values, not subclasses — extend by adding individuals.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?placeType WHERE {
    ?placeType a purrdf:PlaceType .
}
ORDER BY ?placeType
