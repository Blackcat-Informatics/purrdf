# Competency question: "What terms define notability eligibility in PURRDF?"
# Expected: the WP:GNG triad (independent + secondary + significant coverage)
# and the supportsNotability property.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?term WHERE {
    ?term a ?type .
    FILTER(
        ?term IN (
            purrdf:sourceIndependenceIndependent,
            purrdf:sourceTierSecondary,
            purrdf:coverageDepthSignificantCoverage,
            purrdf:supportsNotability
        )
    )
}
ORDER BY ?term
