# Competency question: "What is an organization's headquarters location?"
# Expected: Organizations and their headquarters sites (hasSite + siteTypeHeadquarters).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?org ?hq WHERE {
    ?org purrdf:hasSite ?hq .
    ?hq purrdf:siteType purrdf:siteTypeHeadquarters .
}
ORDER BY ?org ?hq
