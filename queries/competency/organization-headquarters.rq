# Competency question: "What is an organization's headquarters location?"
# Expected: Organizations and their headquarters sites (hasSite + siteTypeHeadquarters).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?org ?hq WHERE {
    ?org gmeow:hasSite ?hq .
    ?hq gmeow:siteType gmeow:siteTypeHeadquarters .
}
ORDER BY ?org ?hq
