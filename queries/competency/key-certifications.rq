# Competency question: "What does a Web-of-Trust certification relate?"
# Expected: the certification's endpoint properties (certifier, certified key,
# certified identity), all domained on gmeow:Certification.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?role WHERE {
    ?role rdfs:domain gmeow:Certification .
}
ORDER BY ?role
