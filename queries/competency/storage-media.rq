# Competency question: "What digital storage media does GMEOW recognise?"
# Expected: the StorageMedium value individuals (cloud service, local filesystem,
# object store, content-addressed store, physical disk, removable media).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?medium WHERE {
    ?medium a gmeow:StorageMedium .
}
ORDER BY ?medium
