# Competency question: "Through which properties does a message reach its
# participants?" Expected: the RFC 5322 role properties, all ranging on the
# gmeow:EmailAddress seam (which joins the message to people and accounts).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?role WHERE {
    ?role rdfs:domain gmeow:EmailMessage ;
          rdfs:range gmeow:EmailAddress .
}
ORDER BY ?role
