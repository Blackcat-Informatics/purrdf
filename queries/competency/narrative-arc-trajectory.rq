# Competency question: "What is a character's emotional trajectory in
# discourse order, per analyzing vantage — and where do analyzers disagree?"
# Expected over instance data: (vantage, ordinal, state) rows ordered by
# vantage then position — the syuzhet-CSV primitive (#361, EPIC #358).
# Disagreement is two vantages' rows at one ordinal with different states:
# visible, never resolved (Principle 9). Over the bare ontology: no rows.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?vantage ?ordinal ?state WHERE {
    ?sample a gmeow:ArcSample ;
        gmeow:vantage ?vantage ;
        gmeow:samplePosition ?pos ;
        gmeow:sampleState ?state .
    ?pos gmeow:positionOrdinal ?ordinal .
}
ORDER BY ?vantage ?ordinal
