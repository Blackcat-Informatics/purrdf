# Competency question: "Which diegetic things co-occur in the same segment —
# the DraCor character-network primitive?"
# Expected over instance data: unordered pairs sharing a carrying segment,
# reachable through EITHER seam orientation (flat narrates, flat narratedIn,
# or a promoted NarrationUsage) — the three forms are one seam (#360, EPIC #358).
# Over the bare ontology this returns no rows (the seam carries no instance
# data of its own); the consumer child (#364) gates it against the corpus.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT DISTINCT ?segment ?a ?b WHERE {
    { ?segment gmeow:narrates ?a . } UNION { ?a gmeow:narratedIn ?segment . }
    UNION { ?d1 a gmeow:NarrationUsage ; gmeow:narrationSegment ?segment ; gmeow:narrationSubject ?a . }
    { ?segment gmeow:narrates ?b . } UNION { ?b gmeow:narratedIn ?segment . }
    UNION { ?d2 a gmeow:NarrationUsage ; gmeow:narrationSegment ?segment ; gmeow:narrationSubject ?b . }
    FILTER(STR(?a) < STR(?b))
}
ORDER BY ?segment ?a ?b
