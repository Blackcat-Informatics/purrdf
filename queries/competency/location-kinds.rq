# Competency question: "What kinds of location does GMEOW model as first-class
# (structurally distinct) classes?" Expected: Location and its subclasses Place,
# VirtualLocation, StorageLocation.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?kind WHERE {
    ?kind rdfs:subClassOf* gmeow:Location .
}
ORDER BY ?kind
