# Competency question: "What kinds of creative work does PURRDF model?"
# Expected: CreativeWork and its subclasses (Document, Article, Patent, Dataset,
# MediaObject, WebPage, SoftwareProduct).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?work WHERE {
    ?work rdfs:subClassOf* purrdf:CreativeWork .
}
ORDER BY ?work
