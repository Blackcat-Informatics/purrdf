# Competency question: "For an employment, what is its occupation and which credentials certify it?"
# Expected: join gmeow:Employment → gmeow:employmentOccupation → gmeow:Occupation
# and gmeow:Credential → gmeow:credentialFor → Occupation (or the occupation's skills).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?employment ?occupation ?credential ?issuer WHERE {
    ?employment a gmeow:Employment ;
                gmeow:employmentOccupation ?occupation .
    ?credential a gmeow:Credential ;
                gmeow:credentialFor ?occupation ;
                gmeow:credentialIssuer ?issuer .
}
ORDER BY ?employment ?credential
