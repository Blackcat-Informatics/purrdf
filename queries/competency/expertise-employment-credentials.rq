# Competency question: "For an employment, what is its occupation and which credentials certify it?"
# Expected: join purrdf:Employment → purrdf:employmentOccupation → purrdf:Occupation
# and purrdf:Credential → purrdf:credentialFor → Occupation (or the occupation's skills).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?employment ?occupation ?credential ?issuer WHERE {
    ?employment a purrdf:Employment ;
                purrdf:employmentOccupation ?occupation .
    ?credential a purrdf:Credential ;
                purrdf:credentialFor ?occupation ;
                purrdf:credentialIssuer ?issuer .
}
ORDER BY ?employment ?credential
