# Competency queries for the accessibility layer (#102).
# These queries demonstrate that the ontology can answer real-world
# accessibility questions.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

# Q1: Find all locations that have a wheelchair accessibility feature
#     and NO wheelchair barrier.
SELECT ?place WHERE {
    ?place gmeow:hasAccessibilityFeature gmeow:facetWheelchair .
    FILTER NOT EXISTS {
        ?place gmeow:hasBarrier gmeow:facetWheelchair .
    }
}

# Q2: Find all accessibility assertions made by a given vantage.
SELECT ?assertion ?subject ?facet ?polarity WHERE {
    ?assertion a gmeow:AccessibilityAssertion ;
        gmeow:assertionSubject ?subject ;
        gmeow:assertionFacet ?facet ;
        gmeow:assertionPolarity ?polarity ;
        gmeow:vantage ?vantage .
}

# Q3: Which locations have barriers for a specific facet?
SELECT ?place ?facet WHERE {
    ?place gmeow:hasBarrier ?facet .
}
