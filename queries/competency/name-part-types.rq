# Competency question: "What name-part kinds does GMEOW recognise across the
# world's naming systems?" Expected: the NamePartType value individuals — given,
# surname, patronymic, the Spanish paternal/maternal pair, the Arabic
# ism/kunya/nasab/laqab/nisba set, mononym, filename stem/extension, … Kinds are
# values, not subclasses — extend by adding individuals.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?namePartType WHERE {
    ?namePartType a gmeow:NamePartType .
}
ORDER BY ?namePartType
