# Competency question: "Which events are self-deception?"
# Self-deception = same agent in deceiver and deceived roles.
# Expected: event-self-deception-001 (when participation data is present).

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?event ?agent WHERE {
    ?event gmeow:eventType gmeow:eventTypeSelfDeception .
    ?event gmeow:hasParticipant ?agent .
}
ORDER BY ?event
