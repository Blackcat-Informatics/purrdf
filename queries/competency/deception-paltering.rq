# Competency question: "Which events are paltering?"
# Paltering = projected implicates a proposition the held claim refutes,
# while the projected literal claim itself is non-refuted.
# Expected: event-paltering-001.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?event WHERE {
    ?event purrdf:eventType purrdf:eventTypePaltering .
    ?event purrdf:implicates ?implicatedProp .
    ?event purrdf:heldStandpoint ?heldClaim .
    ?heldClaim purrdf:claimModality purrdf:refuted .
    ?event purrdf:projectedStandpoint ?projectedClaim .
    FILTER NOT EXISTS { ?projectedClaim purrdf:claimModality purrdf:refuted . }
}
ORDER BY ?event
