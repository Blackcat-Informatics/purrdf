# Competency question: "Ingestion executions that produced claims but no events"
# Expected: Executions of type procedureTypeIngestion whose stepOutput includes
# an Observation (claim) but no Event.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?execution WHERE {
    ?execution a gmeow:Execution .
    ?execution gmeow:executesProcedure / gmeow:procedureType gmeow:procedureTypeIngestion .
    ?execution gmeow:executesStep / gmeow:stepOutput ?output .
    ?output a gmeow:Observation .
    FILTER NOT EXISTS {
        ?execution gmeow:executesStep / gmeow:stepOutput ?event .
        ?event a gmeow:Event .
    }
}
ORDER BY ?execution
