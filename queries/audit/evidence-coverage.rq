# Audit (#55): per-claim grounded-span counts by polarity — the mechanical
# substrate of faithfulness (AIS: coverage over groundedIn links).
PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
SELECT ?claim (COUNT(?span) AS ?spans) (SUM(IF(?polarity = gmeow:polarityRefutes, 1, 0)) AS ?refuting) WHERE {
    ?claim a gmeow:StandpointClaim ;
           gmeow:observationMethod gmeow:methodLlmExtraction .
    OPTIONAL {
        ?claim gmeow:groundedIn ?span .
        ?span gmeow:supportPolarity ?polarity .
    }
}
GROUP BY ?claim
ORDER BY ?claim
