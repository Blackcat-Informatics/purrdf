# Audit (#55): show claims with no evidence — the flagged hallucinations.
# An LLM-extracted claim (observationMethod methodLlmExtraction) with no
# gmeow:groundedIn span is retained and FLAGGED, never deleted (P10).
PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
SELECT ?claim ?model WHERE {
    ?claim a gmeow:StandpointClaim ;
           gmeow:observationMethod gmeow:methodLlmExtraction ;
           gmeow:vantage ?model .
    FILTER NOT EXISTS { ?claim gmeow:groundedIn ?span . }
}
ORDER BY ?claim
