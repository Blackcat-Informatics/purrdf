# Audit (#55): show claims with no evidence — the flagged hallucinations.
# An LLM-extracted claim (observationMethod methodLlmExtraction) with no
# purrdf:groundedIn span is retained and FLAGGED, never deleted (P10).
PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
SELECT ?claim ?model WHERE {
    ?claim a purrdf:StandpointClaim ;
           purrdf:observationMethod purrdf:methodLlmExtraction ;
           purrdf:vantage ?model .
    FILTER NOT EXISTS { ?claim purrdf:groundedIn ?span . }
}
ORDER BY ?claim
