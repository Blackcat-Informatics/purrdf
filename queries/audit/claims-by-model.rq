# Audit (#55): claims grouped by the model vantage and generating invocation —
# 'which model said this, under which call?' as one query.
PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
SELECT ?model ?invocation (COUNT(?claim) AS ?claims) WHERE {
    ?claim a gmeow:StandpointClaim ;
           gmeow:vantage ?model .
    ?model a gmeow:SoftwareAgent .
    OPTIONAL { ?claim gmeow:wasGeneratedBy ?invocation . }
}
GROUP BY ?model ?invocation
ORDER BY ?model
