# ROBOT verify QC (#39) — reasoning-centric meta-grounding (CONSTITUTION P8).
# Every PURRDF class must be punned with a meta-class in EITHER the gUFO namespace
# (gufo:Kind / SubKind / Role / Phase / Category / EventType / …) OR the canonical
# logic: namespace it migrates to (logic:Kind / …, #663/#694). The reasoned-graph
# dual of the exactly_one_stereotype check in crates/validate/src/gufo.rs. A
# non-empty result set is a FAILURE: run with `robot ... verify --queries …`.

PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX gufo: <http://purl.org/nemo/gufo#>
PREFIX logic: <https://blackcatinformatics.ca/logic/>

SELECT ?class WHERE {
    ?class a owl:Class .
    FILTER(STRSTARTS(STR(?class), "https://blackcatinformatics.ca/purrdf/"))
    FILTER NOT EXISTS {
        ?class a ?stereotype .
        FILTER(STRSTARTS(STR(?stereotype), "http://purl.org/nemo/gufo#")
            || STRSTARTS(STR(?stereotype), "https://blackcatinformatics.ca/logic/"))
    }
}
