# ROBOT verify QC (#67) — every NamedPeriod must be bounded.
# A period must have either start and end instants or a temporal
# measurement. A period lacking both is a FAILURE.

PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>

SELECT ?period WHERE {
    ?period a gmeow:NamedPeriod .
    FILTER NOT EXISTS {
        ?period gmeow:periodStart ?start ;
                gmeow:periodEnd ?end .
    }
    FILTER NOT EXISTS {
        ?period gmeow:hasTemporalMeasurement ?tm .
    }
}
