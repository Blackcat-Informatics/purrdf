# ROBOT verify QC (#67) — every NamedPeriod must be bounded.
# A period must have either start and end instants or a temporal
# measurement. A period lacking both is a FAILURE.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?period WHERE {
    ?period a purrdf:NamedPeriod .
    FILTER NOT EXISTS {
        ?period purrdf:periodStart ?start ;
                purrdf:periodEnd ?end .
    }
    FILTER NOT EXISTS {
        ?period purrdf:hasTemporalMeasurement ?tm .
    }
}
