# Negative test: a citation claiming notability support must be a secondary
# source (WP:GNG triad — secondary).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?citation WHERE {
    ?citation a purrdf:CitationAct .
    ?citation purrdf:supportsNotability true .
    FILTER NOT EXISTS {
        ?citation purrdf:sourceTier purrdf:sourceTierSecondary .
    }
}
