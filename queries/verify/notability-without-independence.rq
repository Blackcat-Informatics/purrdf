# Negative test: a citation claiming notability support must be from an
# independent source (WP:GNG triad — independence).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?citation WHERE {
    ?citation a purrdf:CitationAct .
    ?citation purrdf:supportsNotability true .
    FILTER NOT EXISTS {
        ?citation purrdf:sourceIndependence purrdf:sourceIndependenceIndependent .
    }
}
