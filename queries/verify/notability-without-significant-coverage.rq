# Negative test: a citation claiming notability support must provide significant
# coverage (WP:GNG triad — significant coverage).

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>

SELECT ?citation WHERE {
    ?citation a purrdf:CitationAct .
    ?citation purrdf:supportsNotability true .
    FILTER NOT EXISTS {
        ?citation purrdf:coverageDepth purrdf:coverageDepthSignificantCoverage .
    }
}
