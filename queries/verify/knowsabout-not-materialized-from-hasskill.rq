# Native verify QC — the load-bearing regression guard. Removing the strict
# purrdf:hasSkill rdfs:subPropertyOf purrdf:knowsAbout must NOT be silently
# reintroduced: this lane runs over the EL/DL closure, so a re-added subproperty
# axiom would expand into a materialized purrdf:knowsAbout edge and be caught here.
# The canonical source of a purrdf:knowsAbout edge is a declarative-familiarity
# logic:CognitiveAssessment (via the ladder projection) or a deeper rung; a skill
# is defeasible evidence only and never a source under the shipped reasoning.
#
# This returns a row → FAILURE when an agent both has a skill in a subject AND
# knows-about that same subject (asserted or in the EL/DL closure), yet nothing
# legitimately justifies the knowing-about (no deeper rung, and no backing
# declarative-familiarity assessment whose level clears a profile's knows-about
# threshold — the canonical source of knows-about) — the signature of the
# forbidden hasSkill → knowsAbout entailment in the reasoned graph. The exemption
# mirrors the projection rule: a sub-threshold declarative assessment does NOT
# project knows-about, so it must not excuse a knows-about edge here either.

PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX logic: <https://blackcatinformatics.ca/logic/>

SELECT ?agent ?subject WHERE {
    ?agent purrdf:hasSkill ?subject .
    ?agent purrdf:knowsAbout ?subject .
    FILTER NOT EXISTS { ?agent purrdf:understands ?subject }
    FILTER NOT EXISTS { ?agent purrdf:hasMastered ?subject }
    FILTER NOT EXISTS {
        ?assessment logic:assessedAgent ?agent ;
                    logic:assessmentSubject ?subject ;
                    logic:assessmentDimension logic:dimensionDeclarativeFamiliarity ;
                    logic:assessmentLevel ?level .
        ?row logic:projectsLadderEdge purrdf:knowsAbout ;
             logic:sourceDimension logic:dimensionDeclarativeFamiliarity ;
             logic:thresholdLevel ?threshold .
        ?level logic:levelAtOrAbove ?threshold .
    }
}
