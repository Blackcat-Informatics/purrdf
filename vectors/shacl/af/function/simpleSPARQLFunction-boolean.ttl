# Vendored from pySHACL DASH tests:
#   test/resources/dash_tests/function/simpleSPARQLFunction.test.ttl
# See vectors/shacl/af/README.md for provenance and license.
# Original versionInfo: Created with TopBraid Composer
#
# Split from the original combined file so that this validation test only
# exercises the boolean ASK-based sh:SPARQLFunction; the argument variant
# lives in simpleSPARQLFunction-args.ttl.

@prefix ex: <http://datashapes.org/sh/tests/sparql/function/simpleSPARQLFunction.test#> .
@prefix mf: <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sht: <http://www.w3.org/ns/shacl-test#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  rdf:type mf:Manifest ;
  mf:entries (
      <simpleSPARQLFunction-boolean>
    ) ;
.

<simpleSPARQLFunction-boolean>
  rdf:type sht:Validate ;
  rdfs:label "Test of a boolean SPARQL function wrapped in sh:expression" ;
  rdfs:comment "Vendored from pySHACL DASH test function/simpleSPARQLFunction.test.ttl (testBooleanFunction)" ;
  rdfs:seeAlso <http://datashapes.org/sh/tests/sparql/function/simpleSPARQLFunction.test> ;
  mf:action [
      sht:dataGraph <> ;
      sht:shapesGraph <> ;
    ] ;
  mf:result [
      rdf:type sh:ValidationReport ;
      sh:conforms "true"^^xsd:boolean ;
    ] ;
  mf:status sht:approved ;
.

ex:booleanFunction
  rdf:type sh:SPARQLFunction ;
  rdfs:label "boolean function" ;
  sh:ask """ASK {
    FILTER (true) .
  }""" ;
  sh:returnType xsd:boolean ;
.

ex:TestNode
  rdf:type ex:TestClass ;
.

ex:BooleanFunctionShape
  a sh:NodeShape ;
  sh:targetNode ex:TestNode ;
  sh:expression [
      ex:booleanFunction ()
    ] ;
.
