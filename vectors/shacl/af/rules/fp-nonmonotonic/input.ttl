# First-party SHACL Rules case: NON-MONOTONIC condition (fire-at-check-time,
# monotonic accumulation, NO retraction).
#
# The rule is gated on ex:Untagged: a focus node with ZERO ex:tag values
# (sh:maxCount 0 on ex:tag). The rule's own head adds `ex:tag ex:seen`, which
# would make the SAME node FAIL the condition on the next round.
#
# SHACL Rules semantics are monotonic-accumulative: a rule fires for a focus node
# based on the condition holding AT CHECK TIME in the current round; the derived
# triple is added and NEVER retracted, even though re-checking the condition after
# firing would now fail. So ex:alice fires exactly once in round 1 (it then has a
# tag and does not fire again), and the tag is NOT withdrawn. The fixpoint
# converges after the tag stops being new.
#
# Expected derived set: exactly one triple (ex:alice ex:tag ex:seen).

@prefix ex:  <http://example.org/ns#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .

ex:alice rdf:type ex:Person .

ex:Untagged
  rdf:type sh:NodeShape ;
  sh:property [ sh:path ex:tag ; sh:maxCount 0 ] .

ex:TagRule
  rdf:type sh:NodeShape ;
  sh:targetClass ex:Person ;
  sh:rule [
      rdf:type sh:TripleRule ;
      sh:condition ex:Untagged ;
      sh:subject sh:this ;
      sh:predicate ex:tag ;
      sh:object ex:seen ] .
