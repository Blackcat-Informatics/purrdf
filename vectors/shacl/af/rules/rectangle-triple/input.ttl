# DASH-vendored SHACL Rules case: TripleRule whose object is a SPARQLFunction call.
# Source: pySHACL test/resources/dash_tests/rules/triple/rectangle.test.ttl
# Original namespaces preserved (see ../README.md). DASH metadata / owl:imports
# removed; the ex:multiply SPARQLFunction is kept inline.

@prefix ex:   <http://datashapes.org/shasf/tests/rules/triple/rectangle.test#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

ex:ExampleRectangle
  rdf:type ex:Rectangle ;
  ex:height 8 ;
  ex:width 7 .

ex:Rectangle
  rdf:type rdfs:Class ;
  rdfs:subClassOf rdfs:Resource .

ex:RectangleShape
  rdf:type sh:NodeShape ;
  sh:targetClass ex:Rectangle ;
  sh:rule [
      rdf:type sh:TripleRule ;
      sh:subject sh:this ;
      sh:predicate ex:area ;
      sh:object [ ex:multiply ( [ sh:path ex:width ] [ sh:path ex:height ] ) ] ] .

ex:multiply
  rdf:type sh:SPARQLFunction ;
  sh:parameter [ sh:path ex:op1 ; sh:datatype xsd:integer ] ;
  sh:parameter [ sh:path ex:op2 ; sh:datatype xsd:integer ] ;
  sh:returnType xsd:integer ;
  sh:select """SELECT ($op1 * $op2 AS ?result) WHERE { }""" .
