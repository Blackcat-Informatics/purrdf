# DASH-vendored SHACL Rules case: SPARQLRule computing rectangle area.
# Source: pySHACL test/resources/dash_tests/rules/sparql/rectangle.test.ttl
# Original namespaces preserved (see ../README.md). DASH InferencingTestCase
# metadata, owl:imports, and sh:prefixes/sh:declare removed; the SPARQL CONSTRUCT
# resolves prefixes from this document's @prefix declarations.

@prefix ex:   <http://datashapes.org/shasf/tests/rules/sparql/rectangle.test#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

ex:ExampleRectangle
  rdf:type ex:Rectangle ;
  ex:height 8 ;
  ex:width 7 .

ex:Rectangle
  rdf:type rdfs:Class ;
  rdfs:subClassOf rdfs:Resource .

ex:RectangleShape
  rdf:type sh:NodeShape ;
  sh:targetClass ex:Rectangle ;
  sh:rule [
      rdf:type sh:SPARQLRule ;
      sh:construct """
        CONSTRUCT {
          $this ex:area ?area .
        }
        WHERE {
          $this ex:width ?width .
          $this ex:height ?height .
          BIND (?width * ?height AS ?area) .
        }
      """ ] .
