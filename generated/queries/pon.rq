# Projection: PURRDF → pure pon. GENERATED by `purrdf regenerate` (mappings) from mapping-dsl/ — DO NOT EDIT.
# Lossy and directional by design; drops: PON's annotation model presumes Western categories and has no tuning math.
PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX pon: <https://w3id.org/polifonia/ontology/>

CONSTRUCT {
    ?work a pon:Work .
}
WHERE {
    {
        ?work a purrdf:MusicalWork .
        FILTER NOT EXISTS { ?work purrdf:displayable false . }
    }
}
