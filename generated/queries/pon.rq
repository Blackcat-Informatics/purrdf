# Projection: GMEOW → pure pon. GENERATED by `gmeow regenerate` (mappings) from mapping-dsl/ — DO NOT EDIT.
# Lossy and directional by design; drops: PON's annotation model presumes Western categories and has no tuning math.
PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX pon: <https://w3id.org/polifonia/ontology/>

CONSTRUCT {
    ?work a pon:Work .
}
WHERE {
    {
        ?work a gmeow:MusicalWork .
        FILTER NOT EXISTS { ?work gmeow:displayable false . }
    }
}
