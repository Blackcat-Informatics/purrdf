# Projection: PURRDF → pure jcal. GENERATED by `purrdf regenerate` (mappings) from mapping-dsl/ — DO NOT EDIT.
# Lossy and directional by design.
PREFIX purrdf: <https://blackcatinformatics.ca/purrdf/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

CONSTRUCT {
    ?reminder a <https://tools.ietf.org/rfc/rfc7265#valarm> .
    ?reminder <https://tools.ietf.org/rfc/rfc7265#trigger> ?trig .
    ?reminder <https://tools.ietf.org/rfc/rfc7265#action> ?act .
    ?cal a <https://tools.ietf.org/rfc/rfc7265#vcalendar> .
    ?cal <https://tools.ietf.org/rfc/rfc7265#tzid> ?tzid .
    ?task a <https://tools.ietf.org/rfc/rfc7265#vtodo> .
    ?task <https://tools.ietf.org/rfc/rfc7265#due> ?due .
    ?task <https://tools.ietf.org/rfc/rfc7265#priority> ?prio .
    ?task <https://tools.ietf.org/rfc/rfc7265#status> ?ts .
}
WHERE {
    {
        ?reminder purrdf:reminderTrigger ?trig .
        ?reminder purrdf:reminderAction ?act .
        FILTER NOT EXISTS { ?reminder purrdf:displayable false . }
    }
    UNION {
        ?cal rdf:type ?type .
        OPTIONAL { ?cal purrdf:calendarTimeZone ?tz . }
        OPTIONAL { ?tz purrdf:timeZoneIanaId ?tzid . }
        FILTER NOT EXISTS { ?cal purrdf:displayable false . }
    }
    UNION {
        ?task rdf:type ?type .
        OPTIONAL { ?task purrdf:taskDueDate ?due . }
        OPTIONAL { ?task purrdf:taskPriority ?prio . }
        OPTIONAL { ?task purrdf:taskStatus ?ts . }
        FILTER NOT EXISTS { ?task purrdf:displayable false . }
    }
}
