    UNION {
        ?place purrdf:hasPlaceName ?pnx .
        ?pnx purrdf:namePurpose purrdf:namePurposeExonym .
        ?pnx purrdf:fullName ?exo .
        FILTER NOT EXISTS { ?pnx purrdf:displayable false . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?place a purrdf:Place .
        ?place purrdf:hasCoordinates ?coords .
        OPTIONAL {
            ?coords purrdf:latitude ?lat .
        }
        OPTIONAL {
            ?coords purrdf:longitude ?lon .
        }
        OPTIONAL {
            ?coords purrdf:elevation ?elev .
        }
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?place purrdf:coarsenTo ?anyLvl . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?place a purrdf:Place .
        ?place purrdf:coarsenTo ?lvl .
        ?place purrdf:containedInPlace+ ?coarse .
        ?coarse purrdf:hasGranularity ?lvl .
        ?coarse purrdf:hasCoordinates ?ccoords .
        OPTIONAL {
            ?ccoords purrdf:latitude ?lat .
        }
        OPTIONAL {
            ?ccoords purrdf:longitude ?lon .
        }
        BIND ( IRI(CONCAT(STR(?place), "-geo-coarsened")) AS ?coarseGeo )
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
        FILTER NOT EXISTS { ?coarse purrdf:displayable false . }
        FILTER NOT EXISTS { ?coarse purrdf:coarsenTo [] . }
    }
    UNION {
        ?place purrdf:hasPlaceName ?pn .
        ?pn purrdf:fullName ?name .
        FILTER NOT EXISTS { ?pn purrdf:displayable false . }
        FILTER NOT EXISTS { ?pn purrdf:namePurpose ?anyPurpose . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?place purrdf:hasPlaceName ?pn .
        ?pn purrdf:namePurpose purrdf:namePurposeEndonym .
        ?pn purrdf:fullName ?endo .
        FILTER NOT EXISTS { ?pn purrdf:displayable false . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?place purrdf:placeType ?pt .
        VALUES ( ?pt ?ptClass ) {
            ( purrdf:placeTypeCountry schema:Country )
            ( purrdf:placeTypeCity schema:City )
            ( purrdf:placeTypeAdministrativeArea schema:AdministrativeArea )
            ( purrdf:placeTypeRegion schema:AdministrativeArea )
        }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?post a purrdf:Post .
        ?post purrdf:postIn ?postOrg .
        ?mem purrdf:fillsPost ?post .
        ?mem purrdf:hasRole ?role .
        ?role rdfs:label|purrdf:name ?roleName .
        FILTER NOT EXISTS { ?post purrdf:displayable false . }
        FILTER NOT EXISTS { ?mem purrdf:displayable false . }
        FILTER NOT EXISTS { ?role purrdf:displayable false . }
    }
    UNION {
        ?org purrdf:priceRange ?pr .
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
    }
    UNION {
        ?ppPage a purrdf:WebPage .
        ?ppPage purrdf:pagePrincipalSubject ?ppAgent .
        ?ppAgent rdf:type/rdfs:subClassOf* purrdf:Agent .
        FILTER NOT EXISTS { ?ppPage purrdf:displayable false . }
        FILTER NOT EXISTS { ?ppAgent purrdf:displayable false . }
    }
    UNION {
        ?prog a purrdf:ProgrammingLanguage .
        FILTER NOT EXISTS { ?prog purrdf:displayable false . }
    }
    UNION {
        ?splProj purrdf:programmingLanguage ?splLang .
        FILTER NOT EXISTS { ?splProj purrdf:displayable false . }
    }
    UNION {
        ?pubC a purrdf:Contribution .
        ?pubC purrdf:contributionTarget ?pubWork .
        ?pubC purrdf:contributor ?pubAgent .
        ?pubC purrdf:contributionRole purrdf:rolePublisher .
        FILTER NOT EXISTS { ?pubAgent purrdf:displayable false . }
        FILTER NOT EXISTS { ?pubC purrdf:displayable false . }
    }
    UNION {
        ?qWork purrdf:quotesContent ?qSrc .
        FILTER NOT EXISTS { ?qWork purrdf:displayable false . }
    }
    UNION {
        ?qtWork purrdf:quotesContent ?qtSrc .
        ?qtWork purrdf:quotedText ?qtText .
        FILTER NOT EXISTS { ?qtWork purrdf:displayable false . }
    }
    UNION {
        ?recipe a purrdf:Procedure .
        ?recipe purrdf:procedureType purrdf:procedureTypeRecipe .
        FILTER NOT EXISTS { ?recipe purrdf:displayable false . }
    }
    UNION {
        ?step purrdf:stepOutput ?out .
        FILTER NOT EXISTS { ?step purrdf:displayable false . }
    }
    UNION {
        ?route a purrdf:Route .
        FILTER NOT EXISTS { ?route purrdf:displayable false . }
    }
    UNION {
        ?dsSvc purrdf:serviceShutdownDate ?dsDate .
        FILTER NOT EXISTS { ?dsSvc purrdf:displayable false . }
    }
    UNION {
        ?svc a purrdf:ServiceOffering .
        OPTIONAL {
            ?svc purrdf:serviceType ?svcTypeVal .
            ?svcTypeVal rdfs:label ?svcType .
        }
        OPTIONAL {
            ?svc purrdf:areaServed ?svcArea .
        }
        FILTER NOT EXISTS { ?svc purrdf:displayable false . }
    }
    UNION {
        ?scPost purrdf:sharesContent ?scShared .
        FILTER NOT EXISTS { ?scPost purrdf:displayable false . }
    }
    UNION {
        ?prof a purrdf:SkillProficiency .
        ?prof purrdf:skillProficiencyAgent ?agent .
        ?prof purrdf:skillProficiencyOf ?skill .
        FILTER NOT EXISTS { ?prof purrdf:displayable false . }
    }
    UNION {
        ?skillPerson purrdf:hasSkill ?skillVal .
        FILTER NOT EXISTS { ?skillPerson purrdf:displayable false . }
    }
    UNION {
        ?ag purrdf:slogan ?slg .
        FILTER NOT EXISTS { ?ag purrdf:displayable false . }
        OPTIONAL {
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?slg) && LANG(?slg) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?slg), STR(?_extTag)), ?slg) AS ?_final_slg )
    }
    UNION {
        ?spPost a purrdf:FeedPosting .
        ?spPost purrdf:feedPostingKind purrdf:feedPostingKindSocial .
        FILTER NOT EXISTS { ?spPost purrdf:displayable false . }
    }
    UNION {
        ?ssrcRepo a purrdf:Repository .
        OPTIONAL {
            ?ssrcRepo purrdf:webUrl ?ssrcUrl .
        }
        FILTER NOT EXISTS { ?ssrcRepo purrdf:displayable false . }
    }
    UNION {
        ?proc purrdf:hasProcedureStep ?step .
        FILTER NOT EXISTS { ?proc purrdf:displayable false . }
    }
    UNION {
        ?soSub purrdf:subOrganizationOf ?soParent .
        FILTER NOT EXISTS { ?soSub purrdf:displayable false . }
    }
    UNION {
        ?subjWork purrdf:isAbout ?subjTopic .
        FILTER NOT EXISTS { ?subjWork purrdf:displayable false . }
    }
    UNION {
        ?step purrdf:stepInput ?inp .
        FILTER NOT EXISTS { ?step purrdf:displayable false . }
    }
    UNION {
        ?tagging a purrdf:Tagging .
        ?tagging purrdf:taggingTagged ?ent .
        ?tagging purrdf:taggingTag ?tag .
        ?tag rdfs:label ?kw .
        FILTER NOT EXISTS { ?tag purrdf:displayable false . }
        FILTER NOT EXISTS { ?tagging purrdf:displayable false . }
        OPTIONAL {
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?kw) && LANG(?kw) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?kw), STR(?_extTag)), ?kw) AS ?_final_kw )
    }
    UNION {
        ?org purrdf:hasIdentifier ?id .
        ?id purrdf:identifierValue ?tax .
        ?id purrdf:identifierScheme "tax" .
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
        FILTER NOT EXISTS { ?id purrdf:displayable false . }
    }
    UNION {
        ?step purrdf:stepInput ?tool .
        ?tool a purrdf:PhysicalObject .
        FILTER NOT EXISTS { ?step purrdf:displayable false . }
        FILTER NOT EXISTS { ?tool purrdf:displayable false . }
    }
    UNION {
        ?trMedia purrdf:transcript ?trText .
        FILTER NOT EXISTS { ?trMedia purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:hasWebPage ?wp .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:usageInfo ?ui .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
    }
    UNION {
        ?vfEnt purrdf:validFrom ?vfDate .
        FILTER NOT EXISTS { ?vfEnt purrdf:displayable false . }
    }
    UNION {
        ?vtEnt purrdf:validUntil ?vtDate .
        FILTER NOT EXISTS { ?vtEnt purrdf:displayable false . }
    }
    UNION {
        ?verLineage purrdf:hasVersion ?verEntity .
        FILTER NOT EXISTS { ?verLineage purrdf:displayable false . }
    }
    UNION {
        ?vl a purrdf:VirtualLocation .
        OPTIONAL { ?vl purrdf:accessUrl ?vurl . }
        FILTER NOT EXISTS { ?vl purrdf:displayable false . }
    }
    UNION {
        ?wsite a purrdf:WebSite .
        FILTER NOT EXISTS { ?wsite purrdf:displayable false . }
    }
}
