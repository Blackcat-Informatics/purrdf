        ?place gmeow:hasPlaceName ?pnx .
        ?pnx gmeow:namePurpose gmeow:namePurposeExonym .
        ?pnx gmeow:fullName ?exo .
        FILTER NOT EXISTS { ?pnx gmeow:displayable false . }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?place a gmeow:Place .
        ?place gmeow:hasCoordinates ?coords .
        OPTIONAL {
            ?coords gmeow:latitude ?lat .
        }
        OPTIONAL {
            ?coords gmeow:longitude ?lon .
        }
        OPTIONAL {
            ?coords gmeow:elevation ?elev .
        }
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?place gmeow:coarsenTo ?anyLvl . }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?place a gmeow:Place .
        ?place gmeow:coarsenTo ?lvl .
        ?place gmeow:containedInPlace+ ?coarse .
        ?coarse gmeow:hasGranularity ?lvl .
        ?coarse gmeow:hasCoordinates ?ccoords .
        OPTIONAL {
            ?ccoords gmeow:latitude ?lat .
        }
        OPTIONAL {
            ?ccoords gmeow:longitude ?lon .
        }
        BIND ( IRI(CONCAT(STR(?place), "-geo-coarsened")) AS ?coarseGeo )
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
        FILTER NOT EXISTS { ?coarse gmeow:displayable false . }
        FILTER NOT EXISTS { ?coarse gmeow:coarsenTo [] . }
    }
    UNION {
        ?place gmeow:hasPlaceName ?pn .
        ?pn gmeow:fullName ?name .
        FILTER NOT EXISTS { ?pn gmeow:displayable false . }
        FILTER NOT EXISTS { ?pn gmeow:namePurpose ?anyPurpose . }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?place gmeow:hasPlaceName ?pn .
        ?pn gmeow:namePurpose gmeow:namePurposeEndonym .
        ?pn gmeow:fullName ?endo .
        FILTER NOT EXISTS { ?pn gmeow:displayable false . }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?place gmeow:placeType ?pt .
        VALUES ( ?pt ?ptClass ) {
            ( gmeow:placeTypeCountry schema:Country )
            ( gmeow:placeTypeCity schema:City )
            ( gmeow:placeTypeAdministrativeArea schema:AdministrativeArea )
            ( gmeow:placeTypeRegion schema:AdministrativeArea )
        }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?post a gmeow:Post .
        ?post gmeow:postIn ?postOrg .
        ?mem gmeow:fillsPost ?post .
        ?mem gmeow:hasRole ?role .
        ?role rdfs:label|gmeow:name ?roleName .
        FILTER NOT EXISTS { ?post gmeow:displayable false . }
        FILTER NOT EXISTS { ?mem gmeow:displayable false . }
        FILTER NOT EXISTS { ?role gmeow:displayable false . }
    }
    UNION {
        ?org gmeow:priceRange ?pr .
        FILTER NOT EXISTS { ?org gmeow:displayable false . }
    }
    UNION {
        ?ppPage a gmeow:WebPage .
        ?ppPage gmeow:pagePrincipalSubject ?ppAgent .
        ?ppAgent rdf:type/rdfs:subClassOf* gmeow:Agent .
        FILTER NOT EXISTS { ?ppPage gmeow:displayable false . }
        FILTER NOT EXISTS { ?ppAgent gmeow:displayable false . }
    }
    UNION {
        ?prog a gmeow:ProgrammingLanguage .
        FILTER NOT EXISTS { ?prog gmeow:displayable false . }
    }
    UNION {
        ?splProj gmeow:programmingLanguage ?splLang .
        FILTER NOT EXISTS { ?splProj gmeow:displayable false . }
    }
    UNION {
        ?pubC a gmeow:Contribution .
        ?pubC gmeow:contributionTarget ?pubWork .
        ?pubC gmeow:contributor ?pubAgent .
        ?pubC gmeow:contributionRole gmeow:rolePublisher .
        FILTER NOT EXISTS { ?pubAgent gmeow:displayable false . }
        FILTER NOT EXISTS { ?pubC gmeow:displayable false . }
    }
    UNION {
        ?qWork gmeow:quotesContent ?qSrc .
        FILTER NOT EXISTS { ?qWork gmeow:displayable false . }
    }
    UNION {
        ?qtWork gmeow:quotesContent ?qtSrc .
        ?qtWork gmeow:quotedText ?qtText .
        FILTER NOT EXISTS { ?qtWork gmeow:displayable false . }
    }
    UNION {
        ?recipe a gmeow:Procedure .
        ?recipe gmeow:procedureType gmeow:procedureTypeRecipe .
        FILTER NOT EXISTS { ?recipe gmeow:displayable false . }
    }
    UNION {
        ?step gmeow:stepOutput ?out .
        FILTER NOT EXISTS { ?step gmeow:displayable false . }
    }
    UNION {
        ?route a gmeow:Route .
        FILTER NOT EXISTS { ?route gmeow:displayable false . }
    }
    UNION {
        ?dsSvc gmeow:serviceShutdownDate ?dsDate .
        FILTER NOT EXISTS { ?dsSvc gmeow:displayable false . }
    }
    UNION {
        ?svc a gmeow:ServiceOffering .
        OPTIONAL {
            ?svc gmeow:serviceType ?svcTypeVal .
            ?svcTypeVal rdfs:label ?svcType .
        }
        OPTIONAL {
            ?svc gmeow:areaServed ?svcArea .
        }
        FILTER NOT EXISTS { ?svc gmeow:displayable false . }
    }
    UNION {
        ?scPost gmeow:sharesContent ?scShared .
        FILTER NOT EXISTS { ?scPost gmeow:displayable false . }
    }
    UNION {
        ?prof a gmeow:SkillProficiency .
        ?prof gmeow:skillProficiencyAgent ?agent .
        ?prof gmeow:skillProficiencyOf ?skill .
        FILTER NOT EXISTS { ?prof gmeow:displayable false . }
    }
    UNION {
        ?skillPerson gmeow:hasSkill ?skillVal .
        FILTER NOT EXISTS { ?skillPerson gmeow:displayable false . }
    }
    UNION {
        ?ag gmeow:slogan ?slg .
        FILTER NOT EXISTS { ?ag gmeow:displayable false . }
        OPTIONAL {
            ?_lang gmeow:languageTag ?_intTag .
            FILTER(isLiteral(?slg) && LANG(?slg) = ?_intTag)
            ?_lang gmeow:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?slg), STR(?_extTag)), ?slg) AS ?_final_slg )
    }
    UNION {
        ?spPost a gmeow:FeedPosting .
        ?spPost gmeow:feedPostingKind gmeow:feedPostingKindSocial .
        FILTER NOT EXISTS { ?spPost gmeow:displayable false . }
    }
    UNION {
        ?ssrcRepo a gmeow:Repository .
        OPTIONAL {
            ?ssrcRepo gmeow:webUrl ?ssrcUrl .
        }
        FILTER NOT EXISTS { ?ssrcRepo gmeow:displayable false . }
    }
    UNION {
        ?proc gmeow:hasProcedureStep ?step .
        FILTER NOT EXISTS { ?proc gmeow:displayable false . }
    }
    UNION {
        ?soSub gmeow:subOrganizationOf ?soParent .
        FILTER NOT EXISTS { ?soSub gmeow:displayable false . }
    }
    UNION {
        ?subjWork gmeow:isAbout ?subjTopic .
        FILTER NOT EXISTS { ?subjWork gmeow:displayable false . }
    }
    UNION {
        ?step gmeow:stepInput ?inp .
        FILTER NOT EXISTS { ?step gmeow:displayable false . }
    }
    UNION {
        ?tagging a gmeow:Tagging .
        ?tagging gmeow:taggingTagged ?ent .
        ?tagging gmeow:taggingTag ?tag .
        ?tag rdfs:label ?kw .
        FILTER NOT EXISTS { ?tag gmeow:displayable false . }
        FILTER NOT EXISTS { ?tagging gmeow:displayable false . }
        OPTIONAL {
            ?_lang gmeow:languageTag ?_intTag .
            FILTER(isLiteral(?kw) && LANG(?kw) = ?_intTag)
            ?_lang gmeow:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?kw), STR(?_extTag)), ?kw) AS ?_final_kw )
    }
    UNION {
        ?org gmeow:hasIdentifier ?id .
        ?id gmeow:identifierValue ?tax .
        ?id gmeow:identifierScheme "tax" .
        FILTER NOT EXISTS { ?org gmeow:displayable false . }
        FILTER NOT EXISTS { ?id gmeow:displayable false . }
    }
    UNION {
        ?step gmeow:stepInput ?tool .
        ?tool a gmeow:PhysicalObject .
        FILTER NOT EXISTS { ?step gmeow:displayable false . }
        FILTER NOT EXISTS { ?tool gmeow:displayable false . }
    }
    UNION {
        ?trMedia gmeow:transcript ?trText .
        FILTER NOT EXISTS { ?trMedia gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:hasWebPage ?wp .
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:usageInfo ?ui .
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
    }
    UNION {
        ?vfEnt gmeow:validFrom ?vfDate .
        FILTER NOT EXISTS { ?vfEnt gmeow:displayable false . }
    }
    UNION {
        ?vtEnt gmeow:validUntil ?vtDate .
        FILTER NOT EXISTS { ?vtEnt gmeow:displayable false . }
    }
    UNION {
        ?verLineage gmeow:hasVersion ?verEntity .
        FILTER NOT EXISTS { ?verLineage gmeow:displayable false . }
    }
    UNION {
        ?vl a gmeow:VirtualLocation .
        OPTIONAL { ?vl gmeow:accessUrl ?vurl . }
        FILTER NOT EXISTS { ?vl gmeow:displayable false . }
    }
    UNION {
        ?wsite a gmeow:WebSite .
        FILTER NOT EXISTS { ?wsite gmeow:displayable false . }
    }
}
