        OPTIONAL {
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?pmLabel) && LANG(?pmLabel) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?pmLabel), STR(?_extTag)), ?pmLabel) AS ?_final_pmLabel )
    }
    UNION {
        ?pPerf purrdf:participationEvent ?perfEvent .
        ?pPerf purrdf:participationRole purrdf:rolePerformer .
        ?pPerf purrdf:participationParticipant ?performer .
