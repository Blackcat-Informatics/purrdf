        ?occ purrdf:observationResult ?sq2 .
        ?sq2 purrdf:quantityValue ?occVal .
        FILTER NOT EXISTS { ?occ purrdf:displayable false . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
        FILTER NOT EXISTS { ?sq2 purrdf:displayable false . }
    }
    UNION {
        ?ofAgent purrdf:makesOffer ?ofOffer .
