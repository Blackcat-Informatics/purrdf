    UNION {
        ?dpEvent gmeow:eventType gmeow:eventTypeDeath .
        ?dpPart gmeow:participationEvent ?dpEvent .
        ?dpPart gmeow:participationRole gmeow:roleParticipantPrincipal .
        ?dpPart gmeow:participationParticipant ?dpPerson .
        ?dpEvent gmeow:eventLocation ?dpWhere .
