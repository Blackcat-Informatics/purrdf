        ?ddPart purrdf:participationRole purrdf:roleParticipantPrincipal .
        ?ddPart purrdf:participationParticipant ?ddPerson .
        ?ddEvent purrdf:eventTime ?ddWhen .
        FILTER NOT EXISTS { ?ddEvent purrdf:displayable false . }
        FILTER NOT EXISTS { ?ddPart purrdf:displayable false . }
    }
    UNION {
        ?dpEvent purrdf:eventType purrdf:eventTypeDeath .
        ?dpPart purrdf:participationEvent ?dpEvent .
        ?dpPart purrdf:participationRole purrdf:roleParticipantPrincipal .
        ?dpPart purrdf:participationParticipant ?dpPerson .
        ?dpEvent purrdf:eventLocation ?dpWhere .
        FILTER NOT EXISTS { ?dpEvent purrdf:displayable false . }
        FILTER NOT EXISTS { ?dpPart purrdf:displayable false . }
    }
    UNION {
        ?dept purrdf:subOrganizationOf ?parent .
        FILTER NOT EXISTS { ?dept purrdf:displayable false . }
    }
    UNION {
        ?img purrdf:depicts ?subj .
        FILTER NOT EXISTS { ?img purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:description ?desc .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
        FILTER EXISTS { ?ent purrdf:eligibleForConsumer purrdf:consumerPublicSite . }
        OPTIONAL {
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?desc) && LANG(?desc) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?desc), STR(?_extTag)), ?desc) AS ?_final_desc )
    }
    UNION {
        ?org a purrdf:Organization .
        ?org purrdf:hasDestructionEvent ?devent .
        ?devent purrdf:eventTime ?ddate .
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
        FILTER NOT EXISTS { ?devent purrdf:displayable false . }
    }
    UNION {
        ?edWork purrdf:hasEditor ?edAgent .
        FILTER NOT EXISTS { ?edWork purrdf:displayable false . }
