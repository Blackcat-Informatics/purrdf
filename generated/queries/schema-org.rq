        ?exImg purrdf:hasExifTag ?exTag .
        ?exTag purrdf:exifTagId ?exId .
        ?exTag purrdf:exifTagValue ?exVal .
        OPTIONAL {
            ?exTag rdfs:label ?exName .
        }
        FILTER NOT EXISTS { ?exImg purrdf:displayable false . }
        FILTER NOT EXISTS { ?exTag purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:hasAppellation|purrdf:hasName|purrdf:hasOrganizationName|purrdf:hasTitle|purrdf:hasAgreementName|purrdf:hasSoftwareName ?app .
        ?app purrdf:hasNamePart ?np .
        ?np purrdf:namePartType purrdf:namePartSurname .
        ?np purrdf:partText ?family .
        FILTER NOT EXISTS { ?app purrdf:displayable false . }
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
        FILTER NOT EXISTS { ?np purrdf:displayable false . }
        OPTIONAL {
            ?app purrdf:nameLanguage ?_lang .
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?family) && LANG(?family) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
            OPTIONAL { ?app purrdf:nameScript ?_sc . }
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?family), IF(BOUND(?_sc), CONCAT(STR(?_extTag), '-', ?_sc), STR(?_extTag))), ?family) AS ?_final_family )
    }
    UNION {
        ?fOrg purrdf:foundedBy|^purrdf:founderOf ?fAgent .
        FILTER NOT EXISTS { ?fOrg purrdf:displayable false . }
    }
    UNION {
        ?org a purrdf:Organization .
        ?org purrdf:hasCreationEvent ?cevent .
        ?cevent purrdf:eventTime ?fdate .
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
        FILTER NOT EXISTS { ?cevent purrdf:displayable false . }
    }
    UNION {
        ?event purrdf:earliestStart ?start .
        FILTER NOT EXISTS { ?event purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:hasGenderIdentity ?gi .
