    ?oAgent schema:owns ?oItem .
    ?pmePage schema:mainEntity ?pmeEnt .
    ?pmeEnt schema:mainEntityOfPage ?pmePage .
    ?posPage schema:isPartOf ?posSite .
    ?part schema:isPartOf ?whole .
    ?org schema:paymentAccepted ?_final_pmLabel .
    ?perfEvent schema:performer ?performer .
    ?place a schema:Place .
    ?place schema:containedInPlace ?parent .
    ?place schema:name ?allName .
    ?place schema:alternateName ?exo .
    ?place schema:geo ?coarseGeo .
    ?coarseGeo a schema:GeoCoordinates .
    ?coarseGeo schema:latitude ?latDec .
    ?coarseGeo schema:longitude ?lonDec .
    ?place schema:name ?name .
    ?place schema:name ?endo .
    ?place a ?ptClass .
    ?post schema:roleName ?roleName .
    ?org schema:priceRange ?pr .
    ?ppPage a schema:ProfilePage .
    ?prog a schema:ComputerLanguage .
    ?splProj schema:programmingLanguage ?splLang .
    ?pubWork schema:publisher ?pubAgent .
    ?qWork schema:citation ?qSrc .
    ?qSrc a schema:Quotation .
    ?qtSrc schema:text ?qtText .
    ?recipe a schema:Recipe .
    ?step schema:result ?out .
    ?route a schema:Trip .
    ?dsSvc schema:dissolutionDate ?dsDate .
    ?svc a schema:Service .
    ?svc schema:serviceType ?svcType .
    ?svc schema:areaServed ?svcArea .
    ?scPost schema:sharedContent ?scShared .
    ?agent schema:knowsAbout ?skill .
    ?skillPerson schema:skills ?skillVal .
    ?ag schema:slogan ?_final_slg .
    ?spPost a schema:SocialMediaPosting .
    ?ssrcRepo a schema:SoftwareSourceCode .
    ?ssrcRepo schema:codeRepository ?ssrcUrl .
    ?proc schema:step ?step .
    ?soParent schema:subOrganization ?soSub .
    ?subjTopic schema:subjectOf ?subjWork .
    ?step schema:supply ?inp .
    ?org schema:taxID ?tax .
    ?step schema:tool ?tool .
    ?trMedia schema:transcript ?trText .
    ?ent schema:url ?wp .
    ?ent schema:usageInfo ?ui .
    ?vfEnt schema:validFrom ?vfDate .
    ?vtEnt schema:validThrough ?vtDate .
    ?verLineage schema:hasPart ?verEntity .
    ?vl a schema:VirtualLocation .
    ?vl schema:url ?vurl .
    ?wsite a schema:WebSite .
}
WHERE {
    {
        ?absWork purrdf:abstract ?absText .
        FILTER NOT EXISTS { ?absWork purrdf:displayable false . }
    }
    UNION {
        ?place purrdf:hasAccessibilityFeature ?featureFacet .
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?place purrdf:hasBarrier ?hazardFacet .
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:acquireLicensePage ?alp .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
    }
    UNION {
        ?exec a purrdf:Execution .
        FILTER NOT EXISTS { ?exec purrdf:displayable false . }
    }
    UNION {
        ?holder purrdf:hasContactPoint ?addr .
        ?addr a purrdf:PostalAddress .
        OPTIONAL { ?addr purrdf:streetAddress ?street . }
        OPTIONAL { ?addr purrdf:addressLocality ?locality . }
        OPTIONAL { ?addr purrdf:addressRegion ?region . }
        OPTIONAL { ?addr purrdf:postalCode ?pcode . }
        OPTIONAL { ?addr purrdf:countryCode ?ccode . }
        FILTER NOT EXISTS { ?holder purrdf:displayable false . }
        FILTER NOT EXISTS { ?addr purrdf:displayable false . }
    }
    UNION {
        ?affPerson a purrdf:Person .
        ?affPerson purrdf:memberOf ?affOrg .
        FILTER NOT EXISTS { ?affPerson purrdf:displayable false . }
    }
    UNION {
        ?alPerson purrdf:alumniOf ?alOrg .
        FILTER NOT EXISTS { ?alPerson purrdf:displayable false . }
    }
    UNION {
        ?pAtt purrdf:participationEvent ?attEvent .
        ?pAtt purrdf:participationRole purrdf:roleAttendee .
        ?pAtt purrdf:participationParticipant ?attendee .
        FILTER NOT EXISTS { ?pAtt purrdf:displayable false . }
    }
    UNION {
        ?lang rdf:type/rdfs:subClassOf* purrdf:Language .
        ?lang purrdf:languageCode ?code .
        OPTIONAL {
            ?lang purrdf:usesWritingSystem ?ws .
            ?ws purrdf:scriptCode ?sc .
        }
        BIND ( IF(BOUND(?sc), CONCAT(STR(?code), "-", STR(?sc)), STR(?code)) AS ?bcp47 )
        FILTER NOT EXISTS { ?lang rdf:type/rdfs:subClassOf* purrdf:FormalLanguage . }
        FILTER NOT EXISTS { ?lang purrdf:displayable false . }
        FILTER( regex(STR(?code), "^[a-zA-Z]{2,3}$") )
    }
    UNION {
        ?birth purrdf:eventType purrdf:eventTypeBirth .
        ?p purrdf:participationEvent ?birth .
        ?p purrdf:participationRole purrdf:roleParticipantPrincipal .
        ?p purrdf:participationParticipant ?person .
        ?birth purrdf:eventTime ?bdate .
        FILTER NOT EXISTS { ?birth purrdf:displayable false . }
        FILTER NOT EXISTS { ?p purrdf:displayable false . }
    }
    UNION {
        ?bpEvent purrdf:eventType purrdf:eventTypeBirth .
        ?bpPart purrdf:participationEvent ?bpEvent .
        ?bpPart purrdf:participationRole purrdf:roleParticipantPrincipal .
        ?bpPart purrdf:participationParticipant ?bpPerson .
        ?bpEvent purrdf:eventLocation ?bpWhere .
        FILTER NOT EXISTS { ?bpEvent purrdf:displayable false . }
        FILTER NOT EXISTS { ?bpPart purrdf:displayable false . }
    }
    UNION {
        ?bpPost a purrdf:FeedPosting .
        ?bpPost purrdf:feedPostingKind purrdf:feedPostingKindBlog .
        FILTER NOT EXISTS { ?bpPost purrdf:displayable false . }
    }
    UNION {
        ?mark a purrdf:Mark .
        FILTER NOT EXISTS { ?mark purrdf:displayable false . }
    }
    UNION {
        ?cpMedia purrdf:caption ?cpText .
        FILTER NOT EXISTS { ?cpMedia purrdf:displayable false . }
    }
    UNION {
        ?img a purrdf:MediaObject .
        ?img purrdf:captureTime ?ct .
        FILTER NOT EXISTS { ?img purrdf:displayable false . }
    }
    UNION {
        ?crAssess a purrdf:Assessment .
        ?crAssess purrdf:assessmentTarget ?crClaim .
        ?crClaim a purrdf:StandpointClaim .
        OPTIONAL { ?crAssess purrdf:vantage ?crJudge . }
        OPTIONAL {
            ?crAssess purrdf:assessmentScoreValue ?crScore .
        }
        BIND ( IRI(CONCAT(STR(?crAssess), "-rating")) AS ?crRating )
        FILTER NOT EXISTS { ?crAssess purrdf:displayable false . }
        FILTER NOT EXISTS { ?crClaim purrdf:displayable false . }
    }
    UNION {
        ?ceAgent purrdf:email ?ceEmail .
        BIND ( IRI(CONCAT(STR(?ceAgent), "-communicate-email-", ENCODE_FOR_URI(STR(?ceEmail)))) AS ?ceAction )
        BIND ( IRI(CONCAT("mailto:", STR(?ceEmail))) AS ?ceTarget )
        FILTER NOT EXISTS { ?ceAgent purrdf:displayable false . }
    }
    UNION {
        ?cpAgent purrdf:telephone ?cpPhone .
        BIND ( IRI(CONCAT(STR(?cpAgent), "-communicate-phone-", ENCODE_FOR_URI(STR(?cpPhone)))) AS ?cpAction )
        BIND ( IRI(CONCAT("tel:", STR(?cpPhone))) AS ?cpTarget )
        FILTER NOT EXISTS { ?cpAgent purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:conditionsOfAccess ?coa .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
    }
    UNION {
        ?ctWork purrdf:conformsTo ?ctSpec .
        FILTER NOT EXISTS { ?ctWork purrdf:displayable false . }
    }
    UNION {
        ?cpNode a purrdf:ContactPoint .
        FILTER NOT EXISTS { ?cpNode purrdf:displayable false . }
    }
    UNION {
        ?ctPoint purrdf:contactPointType ?ctVal .
        ?ctVal rdfs:label ?ctLabel .
        FILTER NOT EXISTS { ?ctPoint purrdf:displayable false . }
        FILTER NOT EXISTS { ?ctVal purrdf:displayable false . }
        OPTIONAL {
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?ctLabel) && LANG(?ctLabel) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?ctLabel), STR(?_extTag)), ?ctLabel) AS ?_final_ctLabel )
    }
    UNION {
        ?place a purrdf:Place .
        ?place purrdf:hasCoordinateObservation ?obs .
        ?obs purrdf:coordinateResult ?coords .
        OPTIONAL {
            ?coords purrdf:latitude ?lat .
        }
        OPTIONAL {
            ?coords purrdf:longitude ?lon .
        }
        OPTIONAL {
            ?coords purrdf:elevation ?elev .
        }
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?obs purrdf:displayable false . }
        FILTER NOT EXISTS { ?place purrdf:coarsenTo ?anyLvl . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
    }
    UNION {
        ?cw purrdf:hasCopyright ?cr .
        ?cr purrdf:copyrightHolder ?holder .
        FILTER NOT EXISTS { ?cw purrdf:displayable false . }
        FILTER NOT EXISTS { ?cr purrdf:displayable false . }
    }
    UNION {
        ?cw purrdf:hasCopyright ?cr .
        ?cr purrdf:copyrightNotice ?notice .
        FILTER NOT EXISTS { ?cw purrdf:displayable false . }
        FILTER NOT EXISTS { ?cr purrdf:displayable false . }
    }
    UNION {
        ?cw purrdf:hasCopyright ?cr .
        ?cr purrdf:copyrightYear ?yr .
        FILTER NOT EXISTS { ?cw purrdf:displayable false . }
        FILTER NOT EXISTS { ?cr purrdf:displayable false . }
    }
    UNION {
        ?crWork purrdf:hasAuthor ?crAgent .
        FILTER NOT EXISTS { ?crWork purrdf:displayable false . }
    }
    UNION {
        ?cred a purrdf:Credential .
        ?cred purrdf:credentialFor ?target .
        FILTER NOT EXISTS { ?cred purrdf:displayable false . }
    }
    UNION {
        ?cred a purrdf:Credential .
        ?cred purrdf:credentialIssuer ?issuer .
        FILTER NOT EXISTS { ?cred purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:attributionText ?credit .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
    }
    UNION {
        ?org purrdf:acceptsCurrency ?curFrame .
        ?curFrame purrdf:currencyCode ?curCode .
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
        FILTER NOT EXISTS { ?curFrame purrdf:displayable false . }
