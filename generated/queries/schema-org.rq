    UNION {
        ?ent gmeow:description ?desc .
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
        FILTER EXISTS { ?ent gmeow:eligibleForConsumer gmeow:consumerPublicSite . }
        OPTIONAL {
            ?_lang gmeow:languageTag ?_intTag .
            FILTER(isLiteral(?desc) && LANG(?desc) = ?_intTag)
            ?_lang gmeow:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?desc), STR(?_extTag)), ?desc) AS ?_final_desc )
    }
    UNION {
        ?org a gmeow:Organization .
        ?org gmeow:hasDestructionEvent ?devent .
        ?devent gmeow:eventTime ?ddate .
        FILTER NOT EXISTS { ?org gmeow:displayable false . }
        FILTER NOT EXISTS { ?devent gmeow:displayable false . }
