            ?ohSpec purrdf:opensAt ?ohOpens .
        }
        OPTIONAL {
            ?ohSpec purrdf:closesAt ?ohCloses .
        }
        FILTER NOT EXISTS { ?ohOffer purrdf:displayable false . }
