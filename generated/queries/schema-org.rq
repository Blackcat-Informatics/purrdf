        ?na purrdf:networkAddressType purrdf:networkAddressTypeURL .
        ?na purrdf:networkAddressValue ?nval .
        FILTER NOT EXISTS { ?vl purrdf:displayable false . }
        FILTER NOT EXISTS { ?na purrdf:displayable false . }
