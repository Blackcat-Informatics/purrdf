        ?smtC purrdf:contributionTarget ?smtProj .
        ?smtC purrdf:contributor ?smtAgent .
        ?smtC purrdf:contributionRole purrdf:roleSoftwareMaintainer .
        FILTER NOT EXISTS { ?smtAgent purrdf:displayable false . }
        FILTER NOT EXISTS { ?smtC purrdf:displayable false . }
    }
    UNION {
        ?place a purrdf:Place .
        ?place purrdf:hasCapacity ?cap .
        ?cap purrdf:observationResult ?sq .
        ?sq purrdf:quantityValue ?capVal .
        FILTER NOT EXISTS { ?cap purrdf:displayable false . }
        FILTER NOT EXISTS { ?place purrdf:displayable false . }
        FILTER NOT EXISTS { ?sq purrdf:displayable false . }
    }
    UNION {
        ?mpPost a purrdf:FeedPosting .
        ?mpPost purrdf:feedPostingKind purrdf:feedPostingKindMicroblog .
        FILTER NOT EXISTS { ?mpPost purrdf:displayable false . }
    }
    UNION {
        ?card a purrdf:ModelCard .
        ?card purrdf:describesModel ?model .
        OPTIONAL { ?card purrdf:modelVersionTag ?vtag . }
        OPTIONAL { ?model rdfs:label ?mname . }
        FILTER NOT EXISTS { ?card purrdf:displayable false . }
    }
    UNION {
        ?mvEv purrdf:eventFromLocation ?mvFrom .
        FILTER NOT EXISTS { ?mvEv purrdf:displayable false . }
    }
    UNION {
        ?mvtEv purrdf:eventToLocation ?mvTo .
        FILTER NOT EXISTS { ?mvtEv purrdf:displayable false . }
    }
    UNION {
        ?rel a purrdf:Manifestation .
        ?rel purrdf:embodies ?expr .
        ?expr purrdf:realizes ?work .
        ?work a purrdf:MusicalWork .
        FILTER NOT EXISTS { ?rel purrdf:displayable false . }
        FILTER NOT EXISTS { ?expr purrdf:displayable false . }
        FILTER NOT EXISTS { ?work purrdf:displayable false . }
    }
    UNION {
        ?rec a purrdf:Recording .
        FILTER NOT EXISTS { ?rec purrdf:displayable false . }
    }
    UNION {
        ?work a purrdf:MusicalWork .
        FILTER NOT EXISTS { ?work purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:hasAppellation|purrdf:hasName|purrdf:hasOrganizationName|purrdf:hasTitle|purrdf:hasAgreementName|purrdf:hasSoftwareName ?app .
        ?app purrdf:fullName ?dispName .
        FILTER NOT EXISTS { ?app purrdf:displayable false . }
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
        OPTIONAL {
            ?app purrdf:nameLanguage ?_lang .
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?dispName) && LANG(?dispName) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
            OPTIONAL { ?app purrdf:nameScript ?_sc . }
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?dispName), IF(BOUND(?_sc), CONCAT(STR(?_extTag), '-', ?_sc), STR(?_extTag))), ?dispName) AS ?_final_dispName )
    }
    UNION {
        ?natPerson purrdf:nationality ?natCountry .
        FILTER NOT EXISTS { ?natPerson purrdf:displayable false . }
