    ?cpAgent schema:potentialAction ?cpAction .
    ?cpAction a schema:CommunicateAction .
    ?cpAction schema:target ?cpTarget .
    ?ent schema:conditionsOfAccess ?coa .
    ?ctWork schema:conformsTo ?ctSpec .
    ?cpNode a schema:ContactPoint .
    ?ctPoint schema:contactType ?_final_ctLabel .
    ?place schema:geo ?coords .
    ?coords a schema:GeoCoordinates .
    ?coords schema:latitude ?latDec .
    ?coords schema:longitude ?lonDec .
    ?coords schema:elevation ?elev .
    ?cw schema:copyrightHolder ?holder .
    ?cw schema:copyrightNotice ?notice .
