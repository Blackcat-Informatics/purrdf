    ?ent schema:gender ?_final_genderLabel .
    ?claim a schema:Claim .
    ?claim schema:text ?text .
    ?claim schema:appearance ?source .
    ?claim schema:author ?model .
    ?ent schema:givenName ?_final_given .
    ?agent schema:hasCredential ?cred .
    ?whole schema:hasPart ?part .
