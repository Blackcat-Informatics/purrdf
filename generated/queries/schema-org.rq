        OPTIONAL { ?claim purrdf:groundedIn ?span . }
        OPTIONAL { ?span purrdf:spanOfChunk ?chunk . }
        OPTIONAL { ?chunk purrdf:chunkOf ?source . }
        FILTER NOT EXISTS { ?claim purrdf:displayable false . }
        FILTER NOT EXISTS { ?model purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:hasAppellation|purrdf:hasName|purrdf:hasOrganizationName|purrdf:hasTitle|purrdf:hasAgreementName|purrdf:hasSoftwareName ?app .
        ?app purrdf:hasNamePart ?np .
        ?np purrdf:namePartType purrdf:namePartGiven .
        ?np purrdf:partText ?given .
        FILTER NOT EXISTS { ?app purrdf:displayable false . }
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
        FILTER NOT EXISTS { ?np purrdf:displayable false . }
        OPTIONAL {
            ?app purrdf:nameLanguage ?_lang .
            ?_lang purrdf:languageTag ?_intTag .
            FILTER(isLiteral(?given) && LANG(?given) = ?_intTag)
            ?_lang purrdf:bcp47Tag ?_extTag .
            OPTIONAL { ?app purrdf:nameScript ?_sc . }
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?given), IF(BOUND(?_sc), CONCAT(STR(?_extTag), '-', ?_sc), STR(?_extTag))), ?given) AS ?_final_given )
    }
    UNION {
        ?agent purrdf:holdsCredential ?cred .
        FILTER NOT EXISTS { ?agent purrdf:displayable false . }
    }
    UNION {
        ?whole ?hasPartPredicate ?part .
        ?hasPartPredicate rdfs:subPropertyOf* purrdf:hasPart .
        FILTER NOT EXISTS { ?whole purrdf:displayable false . }
        FILTER NOT EXISTS { ?hasPartPredicate purrdf:displayable false . }
    }
    UNION {
        ?org purrdf:hasSite ?site .
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
    }
    UNION {
