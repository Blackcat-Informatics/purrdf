    ?pubWork schema:publisher ?pubAgent .
    ?qWork schema:citation ?qSrc .
    ?qSrc a schema:Quotation .
    ?qtSrc schema:text ?qtText .
    ?recipe a schema:Recipe .
    ?step schema:result ?out .
    ?route a schema:Trip .
    ?dsSvc schema:dissolutionDate ?dsDate .
    ?svc a schema:Service .
    ?svc schema:serviceType ?svcType .
    ?svc schema:areaServed ?svcArea .
    ?scPost schema:sharedContent ?scShared .
    ?agent schema:knowsAbout ?skill .
    ?skillPerson schema:skills ?skillVal .
    ?ag schema:slogan ?_final_slg .
    ?spPost a schema:SocialMediaPosting .
    ?ssrcRepo a schema:SoftwareSourceCode .
    ?ssrcRepo schema:codeRepository ?ssrcUrl .
    ?proc schema:step ?step .
    ?soParent schema:subOrganization ?soSub .
    ?subjTopic schema:subjectOf ?subjWork .
    ?step schema:supply ?inp .
    ?org schema:taxID ?tax .
    ?step schema:tool ?tool .
    ?trMedia schema:transcript ?trText .
    ?ent schema:url ?wp .
    ?ent schema:usageInfo ?ui .
    ?vfEnt schema:validFrom ?vfDate .
    ?vtEnt schema:validThrough ?vtDate .
    ?verLineage schema:hasPart ?verEntity .
    ?vl a schema:VirtualLocation .
    ?vl schema:url ?vurl .
    ?wsite a schema:WebSite .
}
WHERE {
    {
        ?absWork gmeow:abstract ?absText .
        FILTER NOT EXISTS { ?absWork gmeow:displayable false . }
    }
    UNION {
        ?place gmeow:hasAccessibilityFeature ?featureFacet .
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?place gmeow:hasBarrier ?hazardFacet .
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:acquireLicensePage ?alp .
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
    }
    UNION {
        ?exec a gmeow:Execution .
        FILTER NOT EXISTS { ?exec gmeow:displayable false . }
    }
    UNION {
        ?holder gmeow:hasContactPoint ?addr .
        ?addr a gmeow:PostalAddress .
        OPTIONAL { ?addr gmeow:streetAddress ?street . }
        OPTIONAL { ?addr gmeow:addressLocality ?locality . }
        OPTIONAL { ?addr gmeow:addressRegion ?region . }
        OPTIONAL { ?addr gmeow:postalCode ?pcode . }
        OPTIONAL { ?addr gmeow:countryCode ?ccode . }
        FILTER NOT EXISTS { ?holder gmeow:displayable false . }
        FILTER NOT EXISTS { ?addr gmeow:displayable false . }
    }
    UNION {
        ?affPerson a gmeow:Person .
        ?affPerson gmeow:memberOf ?affOrg .
        FILTER NOT EXISTS { ?affPerson gmeow:displayable false . }
    }
    UNION {
        ?alPerson gmeow:alumniOf ?alOrg .
        FILTER NOT EXISTS { ?alPerson gmeow:displayable false . }
    }
    UNION {
        ?pAtt gmeow:participationEvent ?attEvent .
        ?pAtt gmeow:participationRole gmeow:roleAttendee .
        ?pAtt gmeow:participationParticipant ?attendee .
        FILTER NOT EXISTS { ?pAtt gmeow:displayable false . }
    }
    UNION {
        ?lang rdf:type/rdfs:subClassOf* gmeow:Language .
        ?lang gmeow:languageCode ?code .
        OPTIONAL {
            ?lang gmeow:usesWritingSystem ?ws .
            ?ws gmeow:scriptCode ?sc .
        }
        BIND ( IF(BOUND(?sc), CONCAT(STR(?code), "-", STR(?sc)), STR(?code)) AS ?bcp47 )
        FILTER NOT EXISTS { ?lang rdf:type/rdfs:subClassOf* gmeow:FormalLanguage . }
        FILTER NOT EXISTS { ?lang gmeow:displayable false . }
        FILTER( regex(STR(?code), "^[a-zA-Z]{2,3}$") )
    }
    UNION {
        ?birth gmeow:eventType gmeow:eventTypeBirth .
        ?p gmeow:participationEvent ?birth .
        ?p gmeow:participationRole gmeow:roleParticipantPrincipal .
        ?p gmeow:participationParticipant ?person .
        ?birth gmeow:eventTime ?bdate .
        FILTER NOT EXISTS { ?birth gmeow:displayable false . }
        FILTER NOT EXISTS { ?p gmeow:displayable false . }
    }
    UNION {
        ?bpEvent gmeow:eventType gmeow:eventTypeBirth .
        ?bpPart gmeow:participationEvent ?bpEvent .
        ?bpPart gmeow:participationRole gmeow:roleParticipantPrincipal .
        ?bpPart gmeow:participationParticipant ?bpPerson .
        ?bpEvent gmeow:eventLocation ?bpWhere .
        FILTER NOT EXISTS { ?bpEvent gmeow:displayable false . }
        FILTER NOT EXISTS { ?bpPart gmeow:displayable false . }
    }
    UNION {
        ?bpPost a gmeow:FeedPosting .
        ?bpPost gmeow:feedPostingKind gmeow:feedPostingKindBlog .
        FILTER NOT EXISTS { ?bpPost gmeow:displayable false . }
    }
    UNION {
        ?mark a gmeow:Mark .
        FILTER NOT EXISTS { ?mark gmeow:displayable false . }
    }
    UNION {
        ?cpMedia gmeow:caption ?cpText .
        FILTER NOT EXISTS { ?cpMedia gmeow:displayable false . }
    }
    UNION {
        ?img a gmeow:MediaObject .
        ?img gmeow:captureTime ?ct .
        FILTER NOT EXISTS { ?img gmeow:displayable false . }
    }
    UNION {
        ?crAssess a gmeow:Assessment .
        ?crAssess gmeow:assessmentTarget ?crClaim .
        ?crClaim a gmeow:StandpointClaim .
        OPTIONAL { ?crAssess gmeow:vantage ?crJudge . }
        OPTIONAL {
            ?crAssess gmeow:assessmentScoreValue ?crScore .
        }
        BIND ( IRI(CONCAT(STR(?crAssess), "-rating")) AS ?crRating )
        FILTER NOT EXISTS { ?crAssess gmeow:displayable false . }
        FILTER NOT EXISTS { ?crClaim gmeow:displayable false . }
    }
    UNION {
        ?ceAgent gmeow:email ?ceEmail .
        BIND ( IRI(CONCAT(STR(?ceAgent), "-communicate-email-", ENCODE_FOR_URI(STR(?ceEmail)))) AS ?ceAction )
        BIND ( IRI(CONCAT("mailto:", STR(?ceEmail))) AS ?ceTarget )
        FILTER NOT EXISTS { ?ceAgent gmeow:displayable false . }
    }
    UNION {
        ?cpAgent gmeow:telephone ?cpPhone .
        BIND ( IRI(CONCAT(STR(?cpAgent), "-communicate-phone-", ENCODE_FOR_URI(STR(?cpPhone)))) AS ?cpAction )
        BIND ( IRI(CONCAT("tel:", STR(?cpPhone))) AS ?cpTarget )
        FILTER NOT EXISTS { ?cpAgent gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:conditionsOfAccess ?coa .
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
    }
    UNION {
        ?ctWork gmeow:conformsTo ?ctSpec .
        FILTER NOT EXISTS { ?ctWork gmeow:displayable false . }
    }
    UNION {
        ?cpNode a gmeow:ContactPoint .
        FILTER NOT EXISTS { ?cpNode gmeow:displayable false . }
    }
    UNION {
        ?ctPoint gmeow:contactPointType ?ctVal .
        ?ctVal rdfs:label ?ctLabel .
        FILTER NOT EXISTS { ?ctPoint gmeow:displayable false . }
        FILTER NOT EXISTS { ?ctVal gmeow:displayable false . }
        OPTIONAL {
            ?_lang gmeow:languageTag ?_intTag .
            FILTER(isLiteral(?ctLabel) && LANG(?ctLabel) = ?_intTag)
            ?_lang gmeow:bcp47Tag ?_extTag .
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?ctLabel), STR(?_extTag)), ?ctLabel) AS ?_final_ctLabel )
    }
    UNION {
        ?place a gmeow:Place .
        ?place gmeow:hasCoordinateObservation ?obs .
        ?obs gmeow:coordinateResult ?coords .
        OPTIONAL {
            ?coords gmeow:latitude ?lat .
        }
        OPTIONAL {
            ?coords gmeow:longitude ?lon .
        }
        OPTIONAL {
            ?coords gmeow:elevation ?elev .
        }
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?obs gmeow:displayable false . }
        FILTER NOT EXISTS { ?place gmeow:coarsenTo ?anyLvl . }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
    }
    UNION {
        ?cw gmeow:hasCopyright ?cr .
        ?cr gmeow:copyrightHolder ?holder .
        FILTER NOT EXISTS { ?cw gmeow:displayable false . }
        FILTER NOT EXISTS { ?cr gmeow:displayable false . }
    }
    UNION {
        ?cw gmeow:hasCopyright ?cr .
        ?cr gmeow:copyrightNotice ?notice .
        FILTER NOT EXISTS { ?cw gmeow:displayable false . }
        FILTER NOT EXISTS { ?cr gmeow:displayable false . }
    }
    UNION {
        ?cw gmeow:hasCopyright ?cr .
        ?cr gmeow:copyrightYear ?yr .
        FILTER NOT EXISTS { ?cw gmeow:displayable false . }
        FILTER NOT EXISTS { ?cr gmeow:displayable false . }
    }
    UNION {
        ?crWork gmeow:hasAuthor ?crAgent .
        FILTER NOT EXISTS { ?crWork gmeow:displayable false . }
    }
    UNION {
        ?cred a gmeow:Credential .
        ?cred gmeow:credentialFor ?target .
        FILTER NOT EXISTS { ?cred gmeow:displayable false . }
    }
    UNION {
        ?cred a gmeow:Credential .
        ?cred gmeow:credentialIssuer ?issuer .
        FILTER NOT EXISTS { ?cred gmeow:displayable false . }
