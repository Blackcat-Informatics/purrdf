            ( purrdf:organizationTypeCompany schema:Corporation )
            ( purrdf:organizationTypeNonprofit schema:NGO )
            ( purrdf:organizationTypeGovernmentBody schema:GovernmentOrganization )
            ( purrdf:organizationTypeEducationalInstitution schema:EducationalOrganization )
            ( purrdf:organizationTypeAssociation schema:Organization )
            ( purrdf:organizationTypeCollaboration schema:Project )
        }
        FILTER NOT EXISTS { ?org purrdf:displayable false . }
