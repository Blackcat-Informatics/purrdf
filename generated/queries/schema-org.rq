    UNION {
        ?efObj purrdf:mediaType ?efType .
        FILTER NOT EXISTS { ?efObj purrdf:displayable false . }
    }
    UNION {
        ?ent purrdf:authorityLink ?auth .
        ?ent skos:exactMatch ?auth .
        FILTER NOT EXISTS { ?ent purrdf:displayable false . }
    }
