}
WHERE {
    {
        ?prop a purrdf:ObservableProperty .
        FILTER NOT EXISTS { ?prop purrdf:displayable false . }
    }
    UNION {
        ?obs a purrdf:SensoryObservation .
        FILTER NOT EXISTS { ?obs purrdf:displayable false . }
    }
    UNION {
        ?method a purrdf:ObservationMethod .
        FILTER NOT EXISTS { ?method purrdf:displayable false . }
    }
    UNION {
        ?qty a purrdf:ScalarQuantity .
        FILTER NOT EXISTS { ?qty purrdf:displayable false . }
    }
    UNION {
        ?obs a purrdf:SensoryObservation .
        ?obs purrdf:observedFeature ?feature .
        FILTER NOT EXISTS { ?obs purrdf:displayable false . }
    }
}
