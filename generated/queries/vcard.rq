        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?given), IF(BOUND(?_sc), CONCAT(STR(?_extTag), '-', ?_sc), STR(?_extTag))), ?given) AS ?_final_given )
    }
    UNION {
        ?vheAgent gmeow:hasContactPoint ?vheAddr .
        ?vheAddr a gmeow:EmailAddress .
        FILTER NOT EXISTS { ?vheAgent gmeow:displayable false . }
        FILTER NOT EXISTS { ?vheAddr gmeow:displayable false . }
    }
    UNION {
        ?vimAgent gmeow:hasContactPoint ?vimAddr .
        ?vimAddr a gmeow:InstantMessageAddress .
        FILTER NOT EXISTS { ?vimAgent gmeow:displayable false . }
