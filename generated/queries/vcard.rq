WHERE {
    {
        ?holder gmeow:hasContactPoint ?addr .
        ?addr a gmeow:PostalAddress .
        OPTIONAL { ?addr gmeow:streetAddress ?street . }
        OPTIONAL { ?addr gmeow:addressLocality ?locality . }
        OPTIONAL { ?addr gmeow:addressRegion ?region . }
        OPTIONAL { ?addr gmeow:postalCode ?pcode . }
        OPTIONAL { ?addr gmeow:countryCode ?ccode . }
        BIND ( CONCAT(COALESCE(?street, ""), ", ", COALESCE(?locality, ""), " ", COALESCE(?region, ""), " ", COALESCE(?pcode, ""), " ", COALESCE(?ccode, "")) AS ?label )
        FILTER NOT EXISTS { ?holder gmeow:displayable false . }
        FILTER NOT EXISTS { ?addr gmeow:displayable false . }
    }
    UNION {
        ?b gmeow:eventType gmeow:eventTypeBirth .
        ?p gmeow:participationEvent ?b .
        ?p gmeow:participationRole gmeow:roleParticipantPrincipal .
        ?p gmeow:participationParticipant ?ent .
        ?b gmeow:eventTime ?bdate .
        FILTER NOT EXISTS { ?b gmeow:displayable false . }
        FILTER NOT EXISTS { ?p gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:hasAppellation|gmeow:hasName|gmeow:hasOrganizationName|gmeow:hasTitle|gmeow:hasAgreementName|gmeow:hasSoftwareName ?app .
        ?app gmeow:hasNamePart ?np .
        ?np gmeow:namePartType gmeow:namePartSurname .
        ?np gmeow:partText ?family .
        BIND ( IRI(CONCAT(STR(?ent), "-vcardname")) AS ?vname )
        FILTER NOT EXISTS { ?app gmeow:displayable false . }
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
        FILTER NOT EXISTS { ?np gmeow:displayable false . }
        OPTIONAL {
            ?app gmeow:nameLanguage ?_lang .
            ?_lang gmeow:languageTag ?_intTag .
            FILTER(isLiteral(?family) && LANG(?family) = ?_intTag)
            ?_lang gmeow:bcp47Tag ?_extTag .
            OPTIONAL { ?app gmeow:nameScript ?_sc . }
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?family), IF(BOUND(?_sc), CONCAT(STR(?_extTag), '-', ?_sc), STR(?_extTag))), ?family) AS ?_final_family )
    }
    UNION {
        ?ent gmeow:hasAppellation|gmeow:hasName|gmeow:hasOrganizationName|gmeow:hasTitle|gmeow:hasAgreementName|gmeow:hasSoftwareName ?app .
        ?app gmeow:fullName ?dispName .
        FILTER NOT EXISTS { ?app gmeow:displayable false . }
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
        OPTIONAL {
            ?app gmeow:nameLanguage ?_lang .
            ?_lang gmeow:languageTag ?_intTag .
            FILTER(isLiteral(?dispName) && LANG(?dispName) = ?_intTag)
            ?_lang gmeow:bcp47Tag ?_extTag .
            OPTIONAL { ?app gmeow:nameScript ?_sc . }
        }
        BIND ( IF(BOUND(?_extTag), STRLANG(STR(?dispName), IF(BOUND(?_sc), CONCAT(STR(?_extTag), '-', ?_sc), STR(?_extTag))), ?dispName) AS ?_final_dispName )
    }
    UNION {
        ?place a gmeow:Place .
        ?place gmeow:hasCoordinates ?c .
        ?c gmeow:latitude ?lat .
        ?c gmeow:longitude ?lon .
        BIND ( IRI(CONCAT("geo:", STR(?lat), ",", STR(?lon))) AS ?geoNode )
        BIND ( xsd:decimal(?lat) AS ?latDec )
        BIND ( xsd:decimal(?lon) AS ?lonDec )
        FILTER NOT EXISTS { ?place gmeow:coarsenTo ?anyLvl . }
        FILTER NOT EXISTS { ?place gmeow:displayable false . }
        FILTER NOT EXISTS { ?c gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:hasAppellation|gmeow:hasName|gmeow:hasOrganizationName|gmeow:hasTitle|gmeow:hasAgreementName|gmeow:hasSoftwareName ?app .
        ?app gmeow:hasNamePart ?np .
        ?np gmeow:namePartType gmeow:namePartGiven .
        ?np gmeow:partText ?given .
        BIND ( IRI(CONCAT(STR(?ent), "-vcardname")) AS ?vname )
        FILTER NOT EXISTS { ?app gmeow:displayable false . }
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
        FILTER NOT EXISTS { ?np gmeow:displayable false . }
        OPTIONAL {
