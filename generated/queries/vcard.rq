    UNION {
        ?ent gmeow:hasPronounSet ?ps .
        ?ps gmeow:pronounSubject ?psubj .
        ?ps gmeow:pronounObject ?pobj .
        ?ps gmeow:pronounPossessiveDeterminer ?pdet .
        ?ps gmeow:pronounPossessive ?ppos .
        ?ps gmeow:pronounReflexive ?prefl .
        BIND ( CONCAT(?psubj, "/", ?pobj, "/", ?pdet, "/", ?ppos, "/", ?prefl) AS ?pronouns )
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
        FILTER NOT EXISTS { ?ps gmeow:displayable false . }
