    ?addr vcard:locality ?locality .
    ?addr vcard:region ?region .
    ?addr vcard:postal-code ?pcode .
    ?addr vcard:country-name ?ccode .
    ?addr vcard:label ?label .
    ?ent vcard:bday ?bdate .
    ?ent vcard:hasName ?vname .
    ?vname a vcard:Name .
