        ?r rdfs:label|gmeow:name ?title .
        FILTER NOT EXISTS { ?m gmeow:displayable false . }
        FILTER NOT EXISTS { ?r gmeow:displayable false . }
    }
    UNION {
        ?ent gmeow:hasWebPage ?wp .
        FILTER NOT EXISTS { ?ent gmeow:displayable false . }
    }
}
