# Projection: GMEOW → pure sosa. GENERATED by `gmeow regenerate` (mappings) from mapping-dsl/ — DO NOT EDIT.
# Lossy and directional by design; drops: the subproperty distinction (sensoryObservationOf vs spatialMeasurementOf vs generic observedFeature) collapses to flat sosa:hasFeatureOfInterest. Non-displayable observations are suppressed.; only vantage instances that are typed as Sensor are projected to sosa:madeBySensor; other vantage types (person, organization, software agent) are dropped in the SOSA profile. Non-displayable observations are suppressed.; the value-vocabulary individual identity and any external QID alignment are dropped; only the generic sosa:ObservableProperty class survives; the GMEOW value-vocabulary individual identity is preserved as the object node, but any QID alignment or external classification on the ObservableProperty is dropped if not re-typed; SOSA core has no direct platform-location property; bridge via GeoSPARQL geo:location by reference. The place's coordinates, geometry, and granularity are projected separately via the GeoSPARQL projection.; the agent-specific properties (name, description, web page, role) and the platform-location context are dropped; only the generic sosa:Sensor class survives; the platform-specific properties (platformLocation) and any hosted-sensor structure are dropped; only the generic sosa:Platform class survives; the sensory-specific properties (sensoryProperty, sensoryResult, platformLocation), the reference frame, determinacy, granularity, and standpoint are dropped; only the generic sosa:Observation class survives; the unit, determinacy, granularity, reference frame, and standpoint on the result are dropped; only the scalar value node survives. Non-displayable/superseded observations are suppressed..
PREFIX gmeow: <https://blackcatinformatics.ca/gmeow/>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX geo: <http://www.opengis.net/ont/geosparql#>

CONSTRUCT {
    ?obs sosa:hasFeatureOfInterest ?feature .
    ?obs sosa:madeBySensor ?sensor .
    ?prop a sosa:ObservableProperty .
    ?obs sosa:observedProperty ?prop .
    ?platform geo:location ?place .
    ?sensor a sosa:Sensor .
    ?platform a sosa:Platform .
    ?obs a sosa:Observation .
    ?obs sosa:hasResult ?result .
}
WHERE {
    {
        ?obs a gmeow:SensoryObservation .
        ?obs gmeow:sensoryObservationOf ?feature .
        FILTER NOT EXISTS { ?obs gmeow:displayable false . }
    }
    UNION {
        ?obs a gmeow:SensoryObservation .
        ?obs gmeow:vantage ?sensor .
        ?sensor a gmeow:Sensor .
        FILTER NOT EXISTS { ?obs gmeow:displayable false . }
        FILTER NOT EXISTS { ?sensor gmeow:displayable false . }
    }
    UNION {
        ?prop a gmeow:ObservableProperty .
        FILTER NOT EXISTS { ?prop gmeow:displayable false . }
    }
    UNION {
        ?obs gmeow:sensoryProperty ?prop .
        FILTER NOT EXISTS { ?obs gmeow:displayable false . }
    }
    UNION {
        ?platform gmeow:platformLocation ?place .
        FILTER NOT EXISTS { ?platform gmeow:displayable false . }
    }
    UNION {
        ?sensor a gmeow:Sensor .
        FILTER NOT EXISTS { ?sensor gmeow:displayable false . }
    }
    UNION {
        ?platform a gmeow:SensorPlatform .
        FILTER NOT EXISTS { ?platform gmeow:displayable false . }
    }
    UNION {
        ?obs a gmeow:SensoryObservation .
        FILTER NOT EXISTS { ?obs gmeow:displayable false . }
    }
    UNION {
        ?obs a gmeow:SensoryObservation .
        ?obs gmeow:sensoryResult ?result .
        FILTER NOT EXISTS { ?obs gmeow:displayable false . }
    }
}
