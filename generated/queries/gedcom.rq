        FILTER( (?gp1 != ?gp2) )
    }
    UNION {
        ?gmdCouple a purrdf:CoupleRelationship .
        ?gmdCouple purrdf:hasCoupleEvent ?gmdEvent .
        ?gmdEvent purrdf:eventType purrdf:eventTypeMarriage .
        OPTIONAL {
            ?gmdEvent purrdf:eventTime ?gmdDate .
        }
        OPTIONAL {
            ?gmdEvent purrdf:eventLocation ?gmdPlaceEnt .
            ?gmdPlaceEnt rdfs:label ?gmdPlace .
        }
        BIND ( IRI(CONCAT(STR(?gmdCouple), "-marriage")) AS ?gmdMarriage )
        FILTER NOT EXISTS { ?gmdCouple purrdf:displayable false . }
        FILTER NOT EXISTS { ?gmdEvent purrdf:displayable false . }
    }
    UNION {
        ?gsexf purrdf:sexAssignedAtBirth purrdf:saabFemale .
        BIND ( "F" AS ?gsexfVal )
        FILTER NOT EXISTS { ?gsexf purrdf:intersexVariation ?gsexfNote . }
        FILTER NOT EXISTS { ?gsexf purrdf:sexAssignedAtBirth purrdf:saabIntersex . }
        FILTER NOT EXISTS { ?gsexf purrdf:sexAssignedAtBirth purrdf:saabMale . }
        FILTER NOT EXISTS { ?gsexf purrdf:sexAssignedAtBirth purrdf:saabUnknown . }
        FILTER NOT EXISTS { ?gsexf purrdf:displayable false . }
    }
    UNION {
        ?gsexm purrdf:sexAssignedAtBirth purrdf:saabMale .
        BIND ( "M" AS ?gsexmVal )
        FILTER NOT EXISTS { ?gsexm purrdf:intersexVariation ?gsexmNote . }
        FILTER NOT EXISTS { ?gsexm purrdf:sexAssignedAtBirth purrdf:saabFemale . }
        FILTER NOT EXISTS { ?gsexm purrdf:sexAssignedAtBirth purrdf:saabIntersex . }
        FILTER NOT EXISTS { ?gsexm purrdf:sexAssignedAtBirth purrdf:saabUnknown . }
