}
WHERE {
    {
        ?gparent purrdf:hasChild ?gchild .
        FILTER NOT EXISTS { ?gparent purrdf:displayable false . }
    }
    UNION {
        ?gciRel a purrdf:ParentChildRelationship .
        ?gciRel purrdf:relationshipChild ?gciChild .
        ?gciRel purrdf:withinFamily ?gciFam .
        FILTER NOT EXISTS { ?gciRel purrdf:displayable false . }
    }
    UNION {
        ?gfam a purrdf:Family .
        FILTER NOT EXISTS { ?gfam purrdf:displayable false . }
    }
    UNION {
        ?gfmCouple a purrdf:CoupleRelationship .
        ?gfmCouple purrdf:withinFamily ?gfmFam .
        BIND ( IRI(CONCAT(STR(?gfmCouple), "-marriage")) AS ?gfmMarriage )
        FILTER NOT EXISTS { ?gfmCouple purrdf:displayable false . }
    }
    UNION {
        ?ghwCouple a purrdf:CoupleRelationship .
        ?ghwCouple purrdf:hasPartner ?ghwHim .
        ?ghwHim purrdf:sexAssignedAtBirth purrdf:saabMale .
        ?ghwCouple purrdf:hasPartner ?ghwHer .
        ?ghwHer purrdf:sexAssignedAtBirth purrdf:saabFemale .
        BIND ( IRI(CONCAT(STR(?ghwCouple), "-marriage")) AS ?ghwMarriage )
        FILTER NOT EXISTS { ?ghwHer purrdf:intersexVariation ?ghwHerNote . }
        FILTER NOT EXISTS { ?ghwHer purrdf:sexAssignedAtBirth purrdf:saabIntersex . }
        FILTER NOT EXISTS { ?ghwHer purrdf:sexAssignedAtBirth purrdf:saabMale . }
        FILTER NOT EXISTS { ?ghwHer purrdf:sexAssignedAtBirth purrdf:saabUnknown . }
        FILTER NOT EXISTS { ?ghwHim purrdf:intersexVariation ?ghwHimNote . }
        FILTER NOT EXISTS { ?ghwHim purrdf:sexAssignedAtBirth purrdf:saabFemale . }
        FILTER NOT EXISTS { ?ghwHim purrdf:sexAssignedAtBirth purrdf:saabIntersex . }
        FILTER NOT EXISTS { ?ghwHim purrdf:sexAssignedAtBirth purrdf:saabUnknown . }
        FILTER NOT EXISTS { ?ghwCouple purrdf:displayable false . }
        FILTER NOT EXISTS { ?ghwHim purrdf:displayable false . }
        FILTER NOT EXISTS { ?ghwHer purrdf:displayable false . }
        FILTER( (?ghwHim != ?ghwHer) )
    }
    UNION {
        ?gperson a purrdf:Person .
        FILTER NOT EXISTS { ?gperson purrdf:displayable false . }
    }
    UNION {
        ?gcouple a purrdf:CoupleRelationship .
        ?gcouple purrdf:hasPartner ?gp1 .
        ?gcouple purrdf:hasPartner ?gp2 .
        BIND ( IRI(CONCAT(STR(?gcouple), "-marriage")) AS ?gmarriage )
