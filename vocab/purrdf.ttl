#
# The PurRDF carrier vocabulary.
#
# This is deliberately TINY. PurRDF is an RDF toolkit, not an ontology; the
# only terms it mints are the carrier-level predicates its JSON-LD-star
# downcast codec needs to represent RDF 1.2 quoted triples in plain JSON-LD,
# plus one neutral fallback class. Everything else PurRDF reads or writes
# belongs to the caller's vocabulary and is supplied through configuration
# (see the crate documentation for `StatementMetadataVocab` and friends).
#
# Publication: this document is served at <https://blackcatinformatics.ca/purrdf/>
# (the vocabulary namespace). Terms resolve to their definitions below.

@prefix purrdf: <https://blackcatinformatics.ca/purrdf/> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann:   <http://purl.org/vocab/vann/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

<https://blackcatinformatics.ca/purrdf/>
    a owl:Ontology ;
    dcterms:title "PurRDF carrier vocabulary"@en ;
    dcterms:description "Carrier-level terms minted by the PurRDF RDF 1.2 toolkit: the JSON-LD-star statement-metadata downcast encoding, and a neutral fallback class for reifier nodes. PurRDF is a toolkit, not an ontology — every domain term it handles belongs to the calling application's vocabulary."@en ;
    dcterms:creator <https://blackcatinformatics.ca/> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    vann:preferredNamespacePrefix "purrdf" ;
    vann:preferredNamespaceUri "https://blackcatinformatics.ca/purrdf/" ;
    rdfs:seeAlso <https://github.com/Blackcat-Informatics/purrdf> ;
    owl:versionInfo "0.1" .

# ── JSON-LD-star downcast carrier predicates ─────────────────────────────────
#
# RDF 1.2 permits quoted triple terms in the object position. Plain JSON-LD
# (without the star extension) cannot express them, so PurRDF's JSON-LD codec
# downcasts each quoted triple to a resource carrying these four predicates.
# The upcast direction reassembles the quoted triple losslessly.

purrdf:qSubject
    a rdf:Property ;
    rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "quoted subject"@en ;
    rdfs:comment "The subject component of a quoted RDF 1.2 triple in the PurRDF JSON-LD-star downcast encoding."@en .

purrdf:qPredicate
    a rdf:Property ;
    rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "quoted predicate"@en ;
    rdfs:comment "The predicate component of a quoted RDF 1.2 triple in the PurRDF JSON-LD-star downcast encoding."@en .

purrdf:qObject
    a rdf:Property ;
    rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "quoted object (resource)"@en ;
    rdfs:comment "The object component of a quoted RDF 1.2 triple in the PurRDF JSON-LD-star downcast encoding, when the object is an IRI or blank node."@en .

purrdf:qObjectLiteral
    a rdf:Property ;
    rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "quoted object (literal)"@en ;
    rdfs:comment "The object component of a quoted RDF 1.2 triple in the PurRDF JSON-LD-star downcast encoding, when the object is a literal."@en .

# ── SPARQL extension functions ───────────────────────────────────────────────
#
# PurRDF's SPARQL engine exposes a small, closed set of extension functions
# under this namespace. Callers may additionally alias them under their own
# namespace via parser configuration.

purrdf:heldIn
    a rdf:Property ;
    rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "held in"@en ;
    rdfs:comment "SPARQL extension function heldIn(reifier, standpoint) → xsd:boolean: whether a reified statement is held in the given standpoint, per the caller-configured standpoint predicate table."@en .

purrdf:listLength a rdf:Property ; rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "list length"@en ;
    rdfs:comment "SPARQL extension function: the length of an RDF collection."@en .
purrdf:listGet a rdf:Property ; rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "list get"@en ;
    rdfs:comment "SPARQL extension function: the member of an RDF collection at a zero-based index."@en .
purrdf:listIndexOf a rdf:Property ; rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "list index of"@en ;
    rdfs:comment "SPARQL extension function: the zero-based index of a member in an RDF collection, or unbound."@en .
purrdf:listContains a rdf:Property ; rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "list contains"@en ;
    rdfs:comment "SPARQL extension function: whether an RDF collection contains a member."@en .
purrdf:listSlice a rdf:Property ; rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "list slice"@en ;
    rdfs:comment "SPARQL extension function: a sub-collection of an RDF collection by zero-based range."@en .
purrdf:listConcat a rdf:Property ; rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "list concat"@en ;
    rdfs:comment "SPARQL extension function: the concatenation of RDF collections."@en .

# ── Neutral fallback class ───────────────────────────────────────────────────

purrdf:StatementMetadata
    a rdfs:Class ;
    rdfs:isDefinedBy <https://blackcatinformatics.ca/purrdf/> ;
    rdfs:label "statement metadata"@en ;
    rdfs:comment "Neutral fallback class for a reifier node in the JSON-LD-star downcast when the calling application supplies no class of its own. Applications normally override this via the codec's statement-metadata vocabulary configuration."@en .
