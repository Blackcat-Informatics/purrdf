@prefix ex:  <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:x ex:v "5"^^xsd:integer .
ex:y ex:v "7"^^xsd:integer .

# Only x carries the flag.
ex:x ex:flag true .
