#
# Expected CONSTRUCT output for listSlice(( x y z ), 1, 3) → the sub-list ( y z ).
# Blank-node cell labels are compared isomorphically (RDFC-1.0 canonical N-Quads).
@prefix : <http://purrdf.test/list#> .

:out :has ( :y :z ) .
