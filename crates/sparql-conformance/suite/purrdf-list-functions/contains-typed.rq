PREFIX g:   <https://blackcatinformatics.ca/purrdf/>
PREFIX :    <http://purrdf.test/list#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
# The exact term is a member (true); the value-equal xsd:decimal term is not (false).
SELECT ?exact ?distinct WHERE {
  ?q :list ?l .
  BIND(g:listContains(?l, "1"^^xsd:integer) AS ?exact)
  BIND(g:listContains(?l, "1"^^xsd:decimal) AS ?distinct)
}
