@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <http://example.org/ns#> .
@prefix meta: <https://example.org/meta/> .

ex:PersonShape
    a sh:NodeShape ;
    sh:targetNode ex:alice ;
    sh:property ex:KnowsShape .

ex:KnowsShape
    a sh:PropertyShape ;
    meta:graphBoxRole meta:boxCBox ;
    sh:path ex:knows ;
    sh:message "knowledge claims need statement context" ;
    sh:reificationRequired true ;
    sh:reifierShape ex:ProvenanceShape .

ex:ProvenanceShape
    a sh:NodeShape ;
    meta:graphBoxRole meta:boxCBox ;
    sh:property ex:SourceShape .

ex:SourceShape
    a sh:PropertyShape ;
    sh:path ex:source ;
    sh:minCount 1 ;
    sh:message "source required" .
