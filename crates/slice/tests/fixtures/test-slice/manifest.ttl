@prefix purrdf:  <https://blackcatinformatics.ca/purrdf/> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex:      <https://example.org/test/> .

<https://example.org/test/slice/test>
    a purrdf:Slice ;
    rdfs:label "test slice"@x-purrdf-english ;
    dcterms:title "Test Slice"@x-purrdf-english ;
    dcterms:creator "Test Author" ;
    dcterms:identifier "10.99999/test" ;
    purrdf:sliceTier purrdf:tierCore ;
    purrdf:sliceConsumer "For testing only."@x-purrdf-english ;
    ex:unknownCustomProp "custom value"^^<http://www.w3.org/2001/XMLSchema#string> .
